{
  "name": "bilingual-lesson-planner",
  "version": "1.0.0",
  "description": "Bilingual Weekly Lesson Plan Builder",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:skip-check": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "android:copy-lib": "powershell -ExecutionPolicy Bypass -File ./src-tauri/post-build-copy.ps1",
    "android:dev": "npm run android:copy-lib && npm run tauri android dev || (npm run android:copy-lib && echo 'Continuing after symlink error...')",
    "dev:desktop": "tauri dev",
    "dev:mobile": "npm run build && npx cap sync android && npx cap open android",
    "build:mobile": "npm run build && npx cap sync android",
    "cap:sync": "npx cap sync android",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/app": "^7.1.0",
    "@capacitor/cli": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.8.4",
    "axios": "^1.6.2",
    "clsx": "^2.0.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.3.0",
    "tailwind-merge": "^2.1.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.0",
    "@tauri-apps/cli": "^2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.11.17",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.0.7",
    "autoprefixer": "^10.4.16",
    "baseline-browser-mapping": "^2.10.0",
    "jsdom": "^27.1.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^4.0.7"
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bilingual Lesson Planner",
  "version": "1.0.1",
  "identifier": "com.lessonplanner.bilingual",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Bilingual Lesson Planner",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "sidecars": [
        {
          "name": "python-sync-processor",
          "targets": ["android"]
        }
      ]
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}

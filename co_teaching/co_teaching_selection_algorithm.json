{
  "_meta": {
    "schema_version": "1.0",
    "last_updated": "2025-10-04",
    "description": "Heuristic features, hard constraints, and weights for co-teaching model selection with LLM tie-break."
  },
  "features": {
    "time_block_minutes": {"type": "int", "required": true},
    "room_layout_flexibility": {"type": "enum", "values": ["low","medium","high"], "required": true},
    "class_size": {"type": "int", "required": true},
    "wida_distribution": {"type": "object", "required": true, "note": "keys 1-6 counts"},
    "newcomer_pct": {"type": "float", "required": true},
    "dominant_l1_clusters": {"type": "array", "items": {"l1": "string", "count": "int"}},
    "iep_504_pct": {"type": "float"},
    "behavior_tier": {"type": "enum", "values": ["tier1","tier2","tier3"]},
    "content_task_type": {"type": "enum", "values": ["direct","discussion","lab","literacy","assessment"]},
    "skill_emphasis": {"type": "object", "note": "weights for speaking/listening/reading/writing sum to 1.0"},
    "assessment_stakes": {"type": "enum", "values": ["low","high"]},
    "co_planning_minutes_this_week": {"type": "int"},
    "teacher_familiarity_by_model": {"type": "object", "note": "id->low|medium|high"},
    "last_model_used": {"type": "array", "items": "string"},
    "teacher_preference": {"type": "array", "items": "string"},
    "materials_prep_capacity_this_week": {"type": "enum", "values": ["low","medium","high"]},
    "constraints": {"type": "object", "note": "acoustics_limit, tech_available, safety_constraints"}
  },
  "weights": {
    "lesson_context_fit": 0.25,
    "student_profile_fit": 0.25,
    "strategy_compatibility": 0.20,
    "practical_feasibility": 0.20,
    "assessment_integration": 0.10
  },
  "hard_constraints": [
    {"if": {"time_block_minutes": {"lt": 25}}, "drop": ["station"]},
    {"if": {"room_layout_flexibility": "low"}, "penalize": {"station": 0.2, "parallel": 0.15}},
    {"if": {"assessment_stakes": "high"}, "avoid": ["station"]}
  ],
  "rule_bonuses": [
    {"if": {"newcomer_pct": {"gte": 0.25}}, "boost": {"parallel": 0.05, "station": 0.07}},
    {"if": {"dominant_l1_clusters[0].count": {"gte": 6}}, "boost": {"station": 0.05}},
    {"if": {"content_task_type": "discussion"}, "boost": {"parallel": 0.06, "team": 0.06}},
    {"if": {"skill_emphasis.speaking": {"gte": 0.4}}, "boost": {"parallel": 0.05, "team": 0.05}},
    {"if": {"co_planning_minutes_this_week": {"lt": 30}}, "boost": {"one_assist": 0.05, "one_observe": 0.03}, "penalize": {"team": 0.06, "station": 0.08}}
  ],
  "stability": {
    "familiarity_bonus": {"high": 0.06, "medium": 0.03, "low": 0.0},
    "recent_use_penalty": 0.02,
    "transition_cost": {
      "one_observe": {"to": {"parallel": 0.1, "team": 0.2, "station": 0.25, "alternative": 0.15, "one_assist": 0.05}},
      "one_assist": {"to": {"parallel": 0.1, "team": 0.2, "station": 0.25, "alternative": 0.15, "one_observe": 0.05}},
      "parallel": {"to": {"team": 0.1, "station": 0.2, "alternative": 0.15, "one_assist": 0.1, "one_observe": 0.1}},
      "station": {"to": {"parallel": 0.2, "team": 0.2, "alternative": 0.15, "one_assist": 0.1, "one_observe": 0.1}},
      "alternative": {"to": {"parallel": 0.15, "team": 0.15, "station": 0.2, "one_assist": 0.1, "one_observe": 0.1}},
      "team": {"to": {"parallel": 0.1, "station": 0.2, "alternative": 0.15, "one_assist": 0.1, "one_observe": 0.1}}
    },
    "max_phase_transition_cost_sum": 0.4
  },
  "llm_tie_break_prompt": {
    "system": "You are assisting a bilingual co-teaching planner. Output strict JSON only.",
    "constraints": [
      "Use only provided candidate ids",
      "Avoid one_assist unless constraints demand it",
      "Keep minutes sum <= time_block_minutes"
    ],
    "return_format": {
      "top_models": [{"id": "string", "score": "0-1", "why": ["string"]}],
      "phase_plan": [{"phase": "warmup|input|practice|closure", "model_id": "string", "minutes": "int", "note": "string"}],
      "risks": ["string"],
      "mitigations": ["string"]
    }
  }
}



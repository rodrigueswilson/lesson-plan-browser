{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bilingual-lesson-plan-builder.local/schemas/lesson_output_schema.json",
  "title": "Bilingual Lesson Plan Output Schema",
  "description": "JSON schema for WIDA-enhanced bilingual lesson plans with co-teaching and linguistic misconception prediction",
  "version": "1.0.0",
  "type": "object",
  "required": ["metadata", "days"],
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Lesson plan metadata and identification",
      "required": ["week_of", "grade", "subject", "homeroom", "teacher_name"],
      "properties": {
        "week_of": {
          "type": "string",
          "description": "Week date range (MM/DD-MM/DD)",
          "pattern": "^\\d{1,2}/\\d{1,2}-\\d{1,2}/\\d{1,2}$",
          "examples": ["10/6-10/10", "3/15-3/19"]
        },
        "grade": {
          "type": "string",
          "description": "Grade level",
          "examples": ["K", "1", "2", "7", "12"]
        },
        "subject": {
          "type": "string",
          "description": "Subject area",
          "examples": ["Social Studies", "Math", "Language Arts", "Science"]
        },
        "homeroom": {
          "type": "string",
          "description": "Homeroom or class identifier",
          "examples": ["302", "Room 15", "Class A"]
        },
        "room": {
          "type": "string",
          "description": "Room number or physical location where instruction takes place",
          "examples": ["215", "302", "Science Lab A", "Building B, Room 15"]
        },
        "teacher_name": {
          "type": "string",
          "description": "Primary teacher name"
        }
      }
    },
    "days": {
      "type": "object",
      "description": "Lesson plans for each day of the week",
      "required": ["monday", "tuesday", "wednesday", "thursday", "friday"],
      "properties": {
        "monday": { "$ref": "#/definitions/day_plan" },
        "tuesday": { "$ref": "#/definitions/day_plan" },
        "wednesday": { "$ref": "#/definitions/day_plan" },
        "thursday": { "$ref": "#/definitions/day_plan" },
        "friday": { "$ref": "#/definitions/day_plan" }
      }
    }
  },
  "definitions": {
    "day_plan": {
      "description": "Day plan structure. For AI generation, only single-slot is allowed. Multi-slot is for merged data only.",
      "oneOf": [
        {
          "$ref": "#/definitions/day_plan_multi_slot"
        },
        {
          "$ref": "#/definitions/day_plan_single_slot"
        }
      ]
    },
    "day_plan_multi_slot": {
      "type": "object",
      "description": "Multi-slot lesson plan format using slots array. NOTE: This is for merged data only (created by tools/json_merger.py). AI should NEVER generate this structure - only single-slot.",
      "required": ["slots"],
      "properties": {
        "slots": {
          "type": "array",
          "description": "Array of slot-specific lesson plans for this day",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/slot_plan"
          }
        }
      },
      "additionalProperties": false
    },
    "day_plan_single_slot": {
      "type": "object",
      "description": "Single-slot lesson plan format using legacy fields. Use this format when a day has only one lesson slot.",
      "required": [
        "unit_lesson",
        "objective",
        "anticipatory_set",
        "vocabulary_cognates",
        "sentence_frames",
        "tailored_instruction",
        "misconceptions",
        "assessment",
        "homework"
      ],
      "properties": {
        "unit_lesson": {
          "type": "string",
          "description": "Unit, Lesson number, and Module identifier",
          "examples": ["Unit One Lesson Seven", "Module 3 Lesson 12"]
        },
        "objective": {
          "$ref": "#/definitions/objective"
        },
        "anticipatory_set": {
          "$ref": "#/definitions/anticipatory_set"
        },
        "vocabulary_cognates": {
          "$ref": "#/definitions/vocabulary_cognates"
        },
        "sentence_frames": {
          "$ref": "#/definitions/sentence_frames"
        },
        "tailored_instruction": {
          "$ref": "#/definitions/tailored_instruction"
        },
        "misconceptions": {
          "$ref": "#/definitions/misconceptions"
        },
        "assessment": {
          "$ref": "#/definitions/assessment"
        },
        "homework": {
          "$ref": "#/definitions/homework"
        }
      },
      "additionalProperties": false
    },
    "slot_plan": {
      "type": "object",
      "description": "Complete lesson plan for one slot within a day",
      "required": [
        "slot_number",
        "unit_lesson",
        "objective",
        "anticipatory_set",
        "vocabulary_cognates",
        "sentence_frames",
        "tailored_instruction",
        "misconceptions",
        "assessment",
        "homework"
      ],
      "properties": {
        "slot_number": {
          "type": "integer",
          "description": "Slot number (1, 2, 3, etc.)",
          "minimum": 1
        },
        "subject": {
          "type": "string",
          "description": "Subject for this slot",
          "examples": ["ELA", "Math", "Science", "Social Studies"]
        },
        "unit_lesson": {
          "type": "string",
          "description": "Unit, Lesson number, and Module identifier",
          "examples": ["Unit One Lesson Seven", "Module 3 Lesson 12"]
        },
        "objective": {
          "$ref": "#/definitions/objective"
        },
        "anticipatory_set": {
          "$ref": "#/definitions/anticipatory_set"
        },
        "vocabulary_cognates": {
          "$ref": "#/definitions/vocabulary_cognates"
        },
        "sentence_frames": {
          "$ref": "#/definitions/sentence_frames"
        },
        "tailored_instruction": {
          "$ref": "#/definitions/tailored_instruction"
        },
        "misconceptions": {
          "$ref": "#/definitions/misconceptions"
        },
        "assessment": {
          "$ref": "#/definitions/assessment"
        },
        "homework": {
          "$ref": "#/definitions/homework"
        }
      }
    },
    "objective": {
      "type": "object",
      "description": "Tri-objective structure: Content + Student Goal + WIDA Bilingual",
      "required": ["content_objective", "student_goal", "wida_objective"],
      "properties": {
        "content_objective": {
          "type": "string",
          "description": "Original content objective from primary teacher",
          "minLength": 10,
          "examples": ["Students will be able to explain how systems of law and banking enabled growth in trade, wealth, and peace"]
        },
        "student_goal": {
          "type": "string",
          "description": "Student-friendly 'I will...' version (max 12 words for board posting) that explicitly names the WIDA language domains (listening, reading, speaking, writing) students will practice and ends with a parentheses domain tag followed by a period (e.g., '(listening, speaking).')",
          "minLength": 5,
          "maxLength": 120,
          "pattern": "^(?=.*\\b(?:[Ll]isten(?:ing)?|[Rr]ead(?:ing)?|[Ss]peak(?:ing)?|[Ww]rit(?:e|ing))\\b).*\\((?: *(?:listening|reading|speaking|writing))(?: *, *(?:listening|reading|speaking|writing))* *\\)\\.$",
          "examples": ["I will explain Roman systems using evidence and speak with my team (speaking).", "I will read the article, discuss it, and write a summary (reading, speaking, writing)."]
        },
        "wida_objective": {
          "type": "string",
          "description": "Complete WIDA bilingual language objective with ELD standard",
          "minLength": 50,
          "pattern": ".*ELD-[A-Z]{2}\\.[0-9K-]+\\.[A-Za-z]+\\.(?:Listening|Reading|Speaking|Writing)(?:/(?:Listening|Reading|Speaking|Writing))*.*",
          "examples": ["Students will use language to explain how Roman law, banking, and Pax Romana enabled economic growth (ELD-SS.6-8.Explain.Reading/Writing) by using cognate awareness and graphic organizers with Portuguese-English vocabulary bridges appropriate for WIDA levels 2-5, producing a written explanation that demonstrates understanding of cause-effect relationships in historical systems."]
        }
      }
    },
    "anticipatory_set": {
      "type": "object",
      "description": "Lesson opening with bilingual bridge",
      "required": ["original_content", "bilingual_bridge"],
      "properties": {
        "original_content": {
          "type": "string",
          "description": "Original anticipatory set from primary teacher",
          "examples": ["Students will respond to an everybody writes."]
        },
        "bilingual_bridge": {
          "type": "string",
          "description": "1-2 concrete steps to connect L1/culture to lesson entry",
          "minLength": 20,
          "examples": ["Preview key Portuguese-English vocabulary pairs: **law** → *lei*, **banking** → *banco*, **trade** → *comércio*, **peace** → *paz*. Quick L1 connection: 'Como as leis ajudam o comércio?' (How do laws help trade?)"]
        }
      }
    },
    "tailored_instruction": {
      "type": "object",
      "description": "Instructional content with co-teaching model and ELL supports",
      "required": [
        "original_content",
        "co_teaching_model",
        "ell_support",
        "special_needs_support",
        "materials"
      ],
      "properties": {
        "original_content": {
          "type": "string",
          "description": "Original tailored instruction from primary teacher"
        },
        "co_teaching_model": {
          "$ref": "#/definitions/co_teaching_model"
        },
        "ell_support": {
          "type": "array",
          "description": "3-5 bilingual strategies with implementation details",
          "minItems": 3,
          "maxItems": 5,
          "items": {
            "$ref": "#/definitions/ell_strategy"
          }
        },
        "special_needs_support": {
          "type": "array",
          "description": "1-2 simple accommodations",
          "minItems": 1,
          "maxItems": 2,
          "items": {
            "type": "string",
            "minLength": 10,
            "examples": ["Visual timeline of Roman systems; color-code law (blue), banking (green), Pax Romana (gold)"]
          }
        },
        "materials": {
          "type": "array",
          "description": "Concrete, low-prep materials list",
          "items": {
            "type": "string",
            "minLength": 5,
            "examples": ["Bilingual vocabulary chart (poster paper)", "Cornell Notes template (handout)", "Sentence frame strips"]
          }
        }
      }
    },
    "co_teaching_model": {
      "type": "object",
      "description": "WIDA-driven co-teaching model with 45-minute phase plan",
      "required": [
        "model_name",
        "rationale",
        "wida_context",
        "phase_plan",
        "implementation_notes",
        "warnings"
      ],
      "properties": {
        "model_name": {
          "type": "string",
          "description": "Friend & Cook co-teaching model name",
          "enum": [
            "Station Teaching",
            "Parallel Teaching",
            "Team Teaching",
            "Alternative Teaching",
            "One Teach One Assist",
            "One Teach One Observe"
          ]
        },
        "rationale": {
          "type": "string",
          "description": "WIDA band-based reasoning for model selection",
          "minLength": 20,
          "examples": ["Mixed range (4+ levels) needs differentiated stations or dual support"]
        },
        "wida_context": {
          "type": "string",
          "description": "WIDA proficiency distribution description",
          "minLength": 30,
          "examples": ["Mixed range with typical 7th grade distribution (Levels 2-5), requiring differentiated small-group support for complex historical content"]
        },
        "phase_plan": {
          "type": "array",
          "description": "45-minute phase breakdown with teacher roles",
          "minItems": 2,
          "maxItems": 4,
          "items": {
            "$ref": "#/definitions/phase"
          }
        },
        "implementation_notes": {
          "type": "array",
          "description": "Key coordination points, materials, and transitions",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 10,
            "examples": ["Prepare 3 station signs, rotation chart, visual timer"]
          }
        },
        "warnings": {
          "type": "array",
          "description": "Optional warnings about constraints or issues",
          "items": {
            "type": "string",
            "examples": ["Low planning time limits high-intensity model fidelity"]
          }
        }
      }
    },
    "phase": {
      "type": "object",
      "description": "Single phase in 45-minute co-teaching session",
      "required": [
        "phase_name",
        "minutes",
        "bilingual_teacher_role",
        "primary_teacher_role",
        "details"
      ],
      "properties": {
        "phase_name": {
          "type": "string",
          "description": "Phase name (Warmup, Input, Practice, Closure, etc.)",
          "minLength": 3,
          "examples": ["Warmup", "Practice", "Closure", "Input"]
        },
        "minutes": {
          "type": "integer",
          "description": "Duration in minutes",
          "minimum": 1,
          "maximum": 45
        },
        "bilingual_teacher_role": {
          "type": "string",
          "description": "Bilingual teacher's role during this phase",
          "minLength": 10,
          "examples": ["Station 1: Intensive vocabulary/L1 cognate work with Levels 2-3"]
        },
        "primary_teacher_role": {
          "type": "string",
          "description": "Primary teacher's role during this phase",
          "minLength": 10,
          "examples": ["Station 2: Content application with Levels 4-5"]
        },
        "details": {
          "type": "string",
          "description": "Additional phase details (optional)",
          "examples": ["Station 3 (Independent): Bilingual materials practice (all levels rotate). Rotation: 10 minutes per station with visual timer"]
        }
      }
    },
    "ell_strategy": {
      "type": "object",
      "description": "Single ELL support strategy with implementation",
      "required": ["strategy_id", "strategy_name", "implementation", "proficiency_levels"],
      "properties": {
        "strategy_id": {
          "type": "string",
          "description": "Strategy identifier from strategy pack",
          "pattern": "^[a-z_]+$",
          "examples": ["cognate_awareness", "graphic_organizers", "sentence_frames"]
        },
        "strategy_name": {
          "type": "string",
          "description": "Human-readable strategy name",
          "minLength": 5,
          "examples": ["Cognate Awareness", "Graphic Organizers", "Sentence Frames"]
        },
        "implementation": {
          "type": "string",
          "description": "Specific implementation steps for this lesson",
          "minLength": 30,
          "examples": ["Create bilingual vocabulary anchor chart with Portuguese-English pairs: **law** → *lei*, **system** → *sistema*, **economy** → *economia*, **empire** → *império*. Post visibly during slideshow."]
        },
        "proficiency_levels": {
          "type": "string",
          "description": "Target WIDA proficiency levels",
          "pattern": "^Levels? [0-9](-[0-9])?(, [0-9](-[0-9])?)*$",
          "examples": ["Levels 2-5", "Levels 2-3", "Level 1", "Levels 3-4"]
        }
      }
    },
    "misconceptions": {
      "type": "object",
      "description": "Content and linguistic misconceptions",
      "required": ["original_content", "linguistic_note"],
      "properties": {
        "original_content": {
          "type": "string",
          "description": "Original content misconception from primary teacher",
          "examples": ["Students may believe there is no correlation between trade and law"]
        },
        "linguistic_note": {
          "$ref": "#/definitions/linguistic_note"
        }
      }
    },
    "linguistic_note": {
      "type": "object",
      "description": "Portuguese→English interference pattern with prevention",
      "required": ["pattern_id", "note", "prevention_tip"],
      "properties": {
        "pattern_id": {
          "type": "string",
          "description": "Pattern identifier from portuguese_misconceptions.json",
          "enum": [
            "subject_pronoun_omission",
            "adjective_placement",
            "past_tense_ed_dropping",
            "preposition_depend_on",
            "false_cognate_actual",
            "false_cognate_library",
            "default"
          ]
        },
        "note": {
          "type": "string",
          "description": "Explanation of L1→L2 interference",
          "minLength": 30,
          "examples": ["Portuguese speakers often drop subject pronouns ('Go to school' instead of 'I go to school') because verb conjugation shows the person"]
        },
        "prevention_tip": {
          "type": "string",
          "description": "Actionable prevention strategy",
          "minLength": 20,
          "examples": ["Use sentence frames that explicitly include subject pronouns: 'I [verb]...', 'She [verb]...', 'They [verb]...'"]
        }
      }
    },
    "assessment": {
      "type": "object",
      "description": "Primary assessment with bilingual overlay",
      "required": ["primary_assessment", "bilingual_overlay"],
      "properties": {
        "primary_assessment": {
          "type": "string",
          "description": "Original assessment from primary teacher (verbatim)",
          "minLength": 5,
          "examples": ["Exit Ticket", "Quiz on Roman systems", "Presentation"]
        },
        "bilingual_overlay": {
          "$ref": "#/definitions/bilingual_overlay"
        }
      }
    },
    "bilingual_overlay": {
      "type": "object",
      "description": "Primary-Assessment-First overlay with WIDA supports",
      "required": [
        "instrument",
        "wida_mapping",
        "supports_by_level",
        "scoring_lens",
        "constraints_honored"
      ],
      "properties": {
        "instrument": {
          "type": "string",
          "description": "Assessment instrument type and format",
          "minLength": 10,
          "examples": ["Written exit ticket (1-2 sentences)", "Oral presentation (3-5 minutes)", "Multiple choice quiz (10 questions)"]
        },
        "wida_mapping": {
          "type": "string",
          "description": "Key Language Use + ELD domain + proficiency levels",
          "pattern": ".*(Explain|Narrate|Inform|Argue).*ELD.*Level",
          "examples": ["Explain + ELD-SS.6-8.Writing + Levels 2-5"]
        },
        "supports_by_level": {
          "type": "object",
          "description": "Level-banded supports using only available materials",
          "required": ["levels_1_2", "levels_3_4", "levels_5_6"],
          "properties": {
            "levels_1_2": {
              "type": "string",
              "description": "Supports for WIDA Levels 1-2 (Entering/Emerging)",
              "minLength": 20,
              "examples": ["Sentence frame provided, word bank with vocabulary pairs (**law** → *lei*, **system** → *sistema*), allow L1 draft then translate"]
            },
            "levels_3_4": {
              "type": "string",
              "description": "Supports for WIDA Levels 3-4 (Developing/Expanding)",
              "minLength": 20,
              "examples": ["Sentence starter provided, vocabulary pair chart reference (**law** → *lei*, **system** → *sistema*), bilingual dictionary allowed"]
            },
            "levels_5_6": {
              "type": "string",
              "description": "Supports for WIDA Levels 5-6 (Bridging/Reaching)",
              "minLength": 20,
              "examples": ["Open response, optional sentence frames, focus on academic vocabulary"]
            }
          }
        },
        "scoring_lens": {
          "type": "string",
          "description": "Language-focused scoring criteria aligned to primary rubric",
          "minLength": 30,
          "examples": ["Accept responses showing understanding of cause-effect relationship; credit use of academic vocabulary (**law** → *lei*, **banking** → *banco*, **peace** → *paz*); allow code-switching if meaning is clear"]
        },
        "constraints_honored": {
          "type": "string",
          "description": "Confirmation that no new materials or task changes introduced",
          "minLength": 15,
          "examples": ["No new materials; uses existing exit ticket format"]
        }
      }
    },
    "vocabulary_cognates": {
      "type": "array",
      "description": "List of exactly 6 English-Portuguese word pairs highly relevant to lesson objectives",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["english", "portuguese", "is_cognate", "relevance_note"],
        "properties": {
          "english": {
            "type": "string",
            "description": "English word",
            "minLength": 2
          },
          "portuguese": {
            "type": "string",
            "description": "Portuguese word",
            "minLength": 2
          },
          "is_cognate": {
            "type": ["boolean", "null"],
            "description": "Whether this is a true cognate pair (optional, can be null)"
          },
          "relevance_note": {
            "type": ["string", "null"],
            "description": "Brief note on why this word pair is relevant to the lesson (optional, can be null)"
          }
        }
      },
      "examples": [
        [
          {
            "english": "law",
            "portuguese": "lei",
            "is_cognate": false,
            "relevance_note": "Core concept for understanding Roman legal systems"
          },
          {
            "english": "system",
            "portuguese": "sistema",
            "is_cognate": true,
            "relevance_note": "Essential for describing how Roman institutions worked"
          },
          {
            "english": "banking",
            "portuguese": "banco",
            "is_cognate": false,
            "relevance_note": "Key economic institution enabling trade growth"
          },
          {
            "english": "economy",
            "portuguese": "economia",
            "is_cognate": true,
            "relevance_note": "Central to understanding economic growth concepts"
          },
          {
            "english": "trade",
            "portuguese": "comércio",
            "is_cognate": false,
            "relevance_note": "Fundamental concept for lesson on economic systems"
          },
          {
            "english": "peace",
            "portuguese": "paz",
            "is_cognate": false,
            "relevance_note": "Important outcome of effective legal and economic systems"
          }
        ]
      ]
    },
    "sentence_frames": {
      "type": "array",
      "description": "List of exactly 8 sentence frames/stems/questions distributed by WIDA proficiency levels: 3 for Levels 1-2, 3 for Levels 3-4, and 2 for Levels 5-6 (1 stem + 1 open question)",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["proficiency_level", "english", "portuguese", "frame_type", "language_function"],
        "properties": {
          "proficiency_level": {
            "type": "string",
            "description": "WIDA proficiency level group",
            "enum": ["levels_1_2", "levels_3_4", "levels_5_6"]
          },
          "english": {
            "type": "string",
            "description": "English sentence frame/stem/question",
            "minLength": 2
          },
          "portuguese": {
            "type": "string",
            "description": "Portuguese sentence frame/stem/question",
            "minLength": 2
          },
          "language_function": {
            "type": "string",
            "description": "Target language function (e.g., explain, compare, describe, argue)",
            "examples": ["explain", "compare", "describe", "argue", "sequence", "justify"]
          },
          "frame_type": {
            "type": "string",
            "description": "Type of frame: frame for Levels 1-2/3-4, stem or open_question for Levels 5-6",
            "enum": ["frame", "stem", "open_question"]
          }
        }
      },
      "examples": [
        [
          {
            "proficiency_level": "levels_1_2",
            "english": "This is ___",
            "portuguese": "Isto é ___",
            "language_function": "identify",
            "frame_type": "frame"
          },
          {
            "proficiency_level": "levels_1_2",
            "english": "I see ___",
            "portuguese": "Eu vejo ___",
            "language_function": "describe",
            "frame_type": "frame"
          },
          {
            "proficiency_level": "levels_1_2",
            "english": "It has ___",
            "portuguese": "Tem ___",
            "language_function": "describe",
            "frame_type": "frame"
          },
          {
            "proficiency_level": "levels_3_4",
            "english": "First ___, then ___",
            "portuguese": "Primeiro ___, depois ___",
            "language_function": "sequence",
            "frame_type": "frame"
          },
          {
            "proficiency_level": "levels_3_4",
            "english": "This shows ___ because ___",
            "portuguese": "Isso mostra ___ porque ___",
            "language_function": "explain",
            "frame_type": "frame"
          },
          {
            "proficiency_level": "levels_3_4",
            "english": "I think ___ because ___",
            "portuguese": "Eu acho ___ porque ___",
            "language_function": "justify",
            "frame_type": "frame"
          },
          {
            "proficiency_level": "levels_5_6",
            "english": "Evidence suggests that ___",
            "portuguese": "As evidências sugerem que ___",
            "language_function": "argue",
            "frame_type": "stem"
          },
          {
            "proficiency_level": "levels_5_6",
            "english": "How does ___ relate to ___?",
            "portuguese": "Como ___ se relaciona com ___?",
            "language_function": "analyze",
            "frame_type": "open_question"
          }
        ]
      ]
    },
    "homework": {
      "type": "object",
      "description": "Homework assignment with family connection",
      "required": ["original_content", "family_connection"],
      "properties": {
        "original_content": {
          "type": "string",

{
    "title": "Rate Limiter & Redis Monitoring",
    "tags": ["rate-limiter", "redis", "security"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Rate Limit Requests (Allowed vs Blocked)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(limiter_allowed_total[5m])) by (limit_name)",
            "legendFormat": "Allowed - {{limit_name}}",
            "refId": "A"
          },
          {
            "expr": "sum(rate(limiter_blocked_total[5m])) by (limit_name)",
            "legendFormat": "Blocked - {{limit_name}}",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "reqps", "label": "Requests/sec"},
          {"format": "short"}
        ],
        "legend": {"show": true, "values": true, "current": true}
      },
      {
        "id": 2,
        "title": "Circuit Breaker Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "redis_circuit_open",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {"0": {"text": "CLOSED", "color": "green"}}},
              {"type": "value", "options": {"1": {"text": "OPEN", "color": "red"}}}
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "graphMode": "none",
          "colorMode": "value",
          "orientation": "auto"
        }
      },
      {
        "id": 3,
        "title": "Redis Connection Failures",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "redis_connection_failures",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 5, "color": "yellow"},
                {"value": 10, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Rate Limit Block Ratio by Limit Type",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "sum(rate(limiter_blocked_total[5m])) by (limit_name) / sum(rate(limiter_allowed_total[5m]) + rate(limiter_blocked_total[5m])) by (limit_name)",
            "legendFormat": "{{limit_name}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.1, "color": "yellow"},
                {"value": 0.3, "color": "red"}
              ]
            }
          }
        },
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient"
        }
      },
      {
        "id": 5,
        "title": "Redis Failures by Error Type",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "sum(rate(redis_failure_total[5m])) by (error_type)",
            "legendFormat": "{{error_type}}",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "values": ["value", "percent"]
          },
          "pieType": "pie",
          "tooltip": {
            "mode": "single"
          }
        }
      },
      {
        "id": 6,
        "title": "Rate Limit Check Latency (p95)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(rate_limit_check_duration_seconds_bucket[5m])) by (le, limit_name))",
            "legendFormat": "p95 - {{limit_name}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, sum(rate(rate_limit_check_duration_seconds_bucket[5m])) by (le, limit_name))",
            "legendFormat": "p50 - {{limit_name}}",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Latency"},
          {"format": "short"}
        ],
        "legend": {"show": true, "values": true}
      },
      {
        "id": 7,
        "title": "Redis Fallback Events",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "sum(rate(redis_fallback_total[5m])) by (env, service)",
            "legendFormat": "Fallback - {{env}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Events/sec"},
          {"format": "short"}
        ],
        "legend": {"show": true}
      },
      {
        "id": 8,
        "title": "Total Requests by Limit Type",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
        "targets": [
          {
            "expr": "sum(rate(limiter_allowed_total[5m])) by (limit_name)",
            "format": "table",
            "instant": true,
            "refId": "A"
          },
          {
            "expr": "sum(rate(limiter_blocked_total[5m])) by (limit_name)",
            "format": "table",
            "instant": true,
            "refId": "B"
          }
        ],
        "transformations": [
          {
            "id": "merge",
            "options": {}
          },
          {
            "id": "organize",
            "options": {
              "excludeByName": {},
              "indexByName": {
                "limit_name": 0,
                "Value #A": 1,
                "Value #B": 2
              },
              "renameByName": {
                "limit_name": "Limit Type",
                "Value #A": "Allowed (req/s)",
                "Value #B": "Blocked (req/s)"
              }
            }
          }
        ]
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {},
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    }
}


# Bilingual Lesson Plan Builder - Environment Configuration
# Copy this file to .env and update with your values

# Application
APP_NAME="Bilingual Lesson Plan Builder"
APP_VERSION="2.0.0"
DEBUG=false

# Server
HOST=127.0.0.1
PORT=8000
WORKERS=1

# Database
DATABASE_URL=sqlite:///./data/lesson_plans.db

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_API_KEY=your-api-key-here
LLM_MAX_TOKENS=4000
LLM_TEMPERATURE=0.7
# LLM_MAX_COMPLETION_TOKENS=4096  # Optional: Override max completion tokens (auto-detected from model)
# OPENAI_BASE_URL=https://api.openai.com/v1  # Optional: Custom base URL for specialized models
# GPT5_API_KEY=your-gpt5-api-key-here  # Optional: Separate API key for GPT-5 models

# Feature Flags
ENABLE_JSON_OUTPUT=false
JSON_PIPELINE_ROLLOUT_PERCENTAGE=0
ENABLE_TELEMETRY=true

# Token Budget & Performance
MAX_TOKEN_INCREASE_PCT=20
MAX_TOKENS_PER_LESSON=4000
RENDER_TIMEOUT_SECONDS=30

# Validation & Retry
MAX_VALIDATION_RETRIES=3
ENABLE_JSON_REPAIR=true

# Storage & Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/json_pipeline.log
RETAIN_VALIDATED_PAYLOADS=true
MAX_RETAINED_PAYLOADS=100

# Performance Tracking (Session 2)
ENABLE_PERFORMANCE_TRACKING=true
PERFORMANCE_RETENTION_DAYS=90

# Paths
SCHEMA_PATH=schemas/lesson_output_schema.json
TEMPLATE_DIR=templates
OUTPUT_DIR=output

# DOCX Template
DOCX_TEMPLATE_PATH=input/Lesson Plan Template SY'25-26.docx

# Media Anchoring Settings (Session 7)
MEDIA_MATCH_CONFIDENCE_THRESHOLD=0.65
IMAGE_INLINE_MIN_COLUMN_WIDTH_INCHES=1.5
MEDIA_CONTEXT_WINDOW_CHARS=100

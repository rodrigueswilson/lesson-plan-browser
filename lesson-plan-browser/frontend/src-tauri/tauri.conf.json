{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lesson Plan Browser",
  "version": "1.0.0",
  "identifier": "com.lessonplanner.browser",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:skip-check",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Lesson Plan Browser",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": false
  },
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}


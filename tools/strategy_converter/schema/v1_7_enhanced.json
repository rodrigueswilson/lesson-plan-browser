{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bilingual Teaching Strategy Schema v1.7 Enhanced",
  "description": "Schema for bilingual teaching strategies with WIDA alignment and enhanced metadata",
  "version": "1.7_enhanced",
  
  "definitions": {
    "strategy": {
      "type": "object",
      "required": [
        "id",
        "strategy_name",
        "evidence_tier",
        "core_principle",
        "applicable_contexts",
        "implementation_steps",
        "primary_benefits",
        "high_level_categories",
        "primary_skill",
        "skill_weights",
        "delivery_modes",
        "l1_modes",
        "is_integrated_framework"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z_]+$",
          "description": "Unique snake_case identifier"
        },
        "strategy_name": {
          "type": "string",
          "description": "Human-readable strategy name"
        },
        "aliases": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Alternative names for the strategy"
        },
        "present_in": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Sources where strategy appears"
        },
        "evidence_tier": {
          "type": "string",
          "enum": ["research-backed", "practice-based/mixed", "emerging"],
          "description": "Level of research support"
        },
        "core_principle": {
          "type": "string",
          "description": "Concise rationale for the strategy"
        },
        "applicable_contexts": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1,
          "description": "Classroom situations where strategy applies"
        },
        "implementation_steps": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1,
          "description": "Practical how-to guidance"
        },
        "primary_benefits": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1,
          "description": "Expected outcomes"
        },
        "research_foundation": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Key scholars or references"
        },
        "cross_refs": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Related strategy IDs"
        },
        "high_level_categories": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Language Skill Development",
              "Instructional Frameworks & Models",
              "Cross-Linguistic & Biliteracy",
              "Assessment & Scaffolding",
              "Cultural & Identity Affirming",
              "Cognitive & Metacognitive",
              "Content & Language Integration",
              "Social & Interactive Learning"
            ]
          },
          "minItems": 1,
          "description": "Multiple high-level categories (v1.6+)"
        },
        "primary_skill": {
          "type": "string",
          "enum": ["speaking", "listening", "reading", "writing", "integrated"],
          "description": "Primary language skill addressed"
        },
        "secondary_skills": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["speaking", "listening", "reading", "writing"]
          },
          "description": "Additional skills supported"
        },
        "skill_weights": {
          "type": "object",
          "required": ["speaking", "listening", "reading", "writing"],
          "properties": {
            "speaking": {"type": "number", "minimum": 0, "maximum": 1},
            "listening": {"type": "number", "minimum": 0, "maximum": 1},
            "reading": {"type": "number", "minimum": 0, "maximum": 1},
            "writing": {"type": "number", "minimum": 0, "maximum": 1}
          },
          "description": "Numeric weights for each skill (v1.6+)"
        },
        "delivery_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["push-in", "pull-out", "whole-group", "small-group", "individual"]
          },
          "minItems": 1,
          "description": "Implementation contexts (v1.6+)"
        },
        "l1_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["translanguaging", "preview-review", "strategic-code-switch", "none"]
          },
          "minItems": 1,
          "description": "L1 usage patterns (v1.6+)"
        },
        "is_integrated_framework": {
          "type": "boolean",
          "description": "Whether strategy is a comprehensive framework"
        },
        "definitions": {
          "type": "object",
          "properties": {
            "short_en": {
              "type": "string",
              "description": "Brief English definition"
            },
            "long_en": {
              "type": "string",
              "description": "Detailed English explanation"
            },
            "look_fors": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Observable indicators of effective implementation"
            },
            "non_examples": {
              "type": "array",
              "items": {"type": "string"},
              "description": "Common misapplications to avoid"
            }
          },
          "description": "Enhanced definitions (v1.7+)"
        }
      }
    },
    
    "category_file": {
      "type": "object",
      "required": ["_meta", "strategies"],
      "properties": {
        "_meta": {
          "type": "object",
          "required": ["category", "schema_version", "strategy_count"],
          "properties": {
            "category": {"type": "string"},
            "description": {"type": "string"},
            "schema_version": {"type": "string"},
            "strategy_count": {"type": "integer", "minimum": 1},
            "last_updated": {"type": "string", "format": "date"},
            "wida_aligned": {"type": "boolean"},
            "includes_definitions": {"type": "boolean"}
          }
        },
        "strategies": {
          "type": "array",
          "items": {"$ref": "#/definitions/strategy"},
          "minItems": 1
        }
      }
    }
  },
  
  "oneOf": [
    {"$ref": "#/definitions/strategy"},
    {"$ref": "#/definitions/category_file"}
  ]
}

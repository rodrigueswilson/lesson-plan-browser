"""Test objectives DOCX generation with existing JSON files."""
import sys
import json
from pathlib import Path

# Add backend to path
sys.path.insert(0, str(Path(__file__).parent))

from backend.services.objectives_printer import ObjectivesPrinter

def test_objectives_docx():
    """Test objectives DOCX generation."""
    
    # Try to find a JSON file with lesson plan data
    json_files = [
        "output/test_merged.json",
        "output/direct_mock_lesson.json",
        "output/test_media_e2e.json"
    ]
    
    lesson_json = None
    json_file_path = None
    
    for json_file in json_files:
        json_path = Path(json_file)
        if json_path.exists():
            print(f"Found JSON file: {json_file}")
            try:
                with open(json_path, 'r', encoding='utf-8') as f:
                    data = json.load(f)
                
                # Check if it has the expected structure
                if isinstance(data, dict):
                    # Check if it's a lesson plan structure
                    if 'days' in data or 'metadata' in data:
                        lesson_json = data
                        json_file_path = json_path
                        print(f"SUCCESS: Loaded lesson plan from {json_file}\n")
                        break
                    # Check if it's wrapped in another structure
                    elif 'lesson_json' in data:
                        lesson_json = data['lesson_json']
                        json_file_path = json_path
                        print(f"SUCCESS: Loaded lesson plan from {json_file} (extracted from wrapper)\n")
                        break
            except Exception as e:
                print(f"Error loading {json_file}: {e}")
                continue
    
    if not lesson_json:
        print("ERROR: No suitable lesson plan JSON files found.")
        print("Available JSON files:")
        for json_file in json_files:
            if Path(json_file).exists():
                print(f"  - {json_file}")
        return
    
    # Extract objectives to verify
    printer = ObjectivesPrinter()
    objectives = printer.extract_objectives(lesson_json)
    print(f"Found {len(objectives)} objectives to generate\n")
    
    if not objectives:
        print("ERROR: No objectives found in lesson plan. Cannot generate DOCX.")
        print("\nLesson plan structure:")
        print(f"  Keys: {list(lesson_json.keys())}")
        if 'days' in lesson_json:
            print(f"  Days: {list(lesson_json['days'].keys())}")
        return
    
    # Show first few objectives
    print("Sample objectives:")
    for i, obj in enumerate(objectives[:3], 1):
        print(f"\n{i}. {obj['day']} - Slot {obj['slot_number']} ({obj['subject']})")
        student_goal = obj['student_goal'][:80] if obj['student_goal'] else "N/A"
        wida_obj = obj['wida_objective'][:80] if obj['wida_objective'] else "N/A"
        print(f"   Student Goal: {student_goal}...")
        print(f"   WIDA Objective: {wida_obj}...")
    
    if len(objectives) > 3:
        print(f"\n... and {len(objectives) - 3} more objectives")
    
    # Get metadata
    metadata = lesson_json.get('metadata', {})
    week_of = metadata.get('week_of', 'Unknown')
    user_name = metadata.get('teacher_name', 'Test User')
    
    # Generate DOCX
    print("\n" + "="*60)
    print("Generating objectives DOCX...")
    print("="*60)
    
    output_path = Path("output") / f"test_objectives_{json_file_path.stem}.docx"
    output_path.parent.mkdir(parents=True, exist_ok=True)
    
    try:
        docx_path = printer.generate_docx(
            lesson_json=lesson_json,
            output_path=str(output_path),
            user_name=user_name,
            week_of=week_of
        )
        
        print(f"\nSUCCESS: Successfully generated objectives DOCX!")
        print(f"   Output file: {docx_path}")
        print(f"   Total pages: {len(objectives)} (one per lesson)")
        print(f"   Week: {week_of}")
        print(f"\nYou can now open the file to verify the layout:")
        print(f"   {Path(docx_path).absolute()}")
        
    except Exception as e:
        print(f"\nERROR: Error generating DOCX: {e}")
        import traceback
        traceback.print_exc()

if __name__ == '__main__':
    test_objectives_docx()

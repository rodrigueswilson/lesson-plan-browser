"""
Test step creation to see if vocabulary_cognates is being saved correctly.
"""
import sys
import json
import uuid
from pathlib import Path
from datetime import datetime

sys.path.append(str(Path(__file__).parent))

from backend.database import get_db

# Test vocabulary step creation
plan_id = "plan_20251122160826"
db = get_db()

vocab_data = [
    {"english": "state", "portuguese": "estado", "is_cognate": False, "relevance_note": "Test"},
    {"english": "coast", "portuguese": "costa", "is_cognate": True, "relevance_note": "Test"}
]

vocab_step_data = {
    "id": str(uuid.uuid4()),
    "lesson_plan_id": plan_id,
    "day_of_week": "monday",
    "slot_number": 1,
    "step_number": 999,  # Use high number so we can find it easily
    "step_name": "TEST Vocabulary Step",
    "duration_minutes": 5,
    "start_time_offset": 0,
    "content_type": "instruction",
    "display_content": "Test content",
    "hidden_content": [],
    "sentence_frames": [],
    "materials_needed": [],
    "vocabulary_cognates": vocab_data,  # This should be saved
}

print(f"Creating test step with vocabulary_cognates...")
print(f"  vocabulary_cognates type: {type(vocab_data)}")
print(f"  vocabulary_cognates value: {vocab_data}")

try:
    step_id = db.create_lesson_step(vocab_step_data)
    print(f"[OK] Step created: {step_id}")
    
    # Read it back
    steps = db.get_lesson_steps(plan_id, day_of_week="monday", slot_number=1)
    test_step = next((s for s in steps if s.step_number == 999), None)
    
    if test_step:
        print(f"\n[OK] Found test step: {test_step.step_name}")
        print(f"  vocabulary_cognates attribute exists: {hasattr(test_step, 'vocabulary_cognates')}")
        vocab_retrieved = test_step.vocabulary_cognates if hasattr(test_step, 'vocabulary_cognates') else None
        print(f"  vocabulary_cognates type: {type(vocab_retrieved)}")
        print(f"  vocabulary_cognates value: {vocab_retrieved}")
        
        if vocab_retrieved and isinstance(vocab_retrieved, list) and len(vocab_retrieved) > 0:
            print(f"[OK] vocabulary_cognates was saved and retrieved correctly!")
            print(f"     Count: {len(vocab_retrieved)} items")
            print(f"     First item: {vocab_retrieved[0]}")
        else:
            print(f"[FAIL] vocabulary_cognates was NOT saved correctly")
            print(f"        Expected: {vocab_data}")
            print(f"        Got: {vocab_retrieved}")
    else:
        print(f"[FAIL] Test step not found after creation")
        
    # Cleanup
    print(f"\nCleaning up test step...")
    from backend.schema import LessonStep
    from sqlmodel import Session, delete
    with Session(db.engine) as session:
        session.exec(delete(LessonStep).where(LessonStep.id == step_id))
        session.commit()
    print(f"[OK] Test step deleted")
    
except Exception as e:
    print(f"[FAIL] Error: {e}")
    import traceback
    traceback.print_exc()


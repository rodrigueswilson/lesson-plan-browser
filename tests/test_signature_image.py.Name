"""
Simple script to test signature functionality in the signature table.
Tests:
1. Signature image insertion (if provided)
2. User name insertion (underlined) when no signature image
3. Date insertion (underlined)

Generates a Word document with the signature box properly filled.
"""

from datetime import datetime
from pathlib import Path
from docx import Document
from tools.batch_processor import BatchProcessor

# Configuration
TEMPLATE_PATH = "input/Lesson Plan Template SY'25-26.docx"
SIGNATURE_IMAGE_PATH = r"F:\rodri\Documents\OneDrive\AS\Lesson Plan\wilson_rodrigues_signature.PNG"
OUTPUT_PATH = "output/test_signature.docx"
USER_NAME = "Wilson Rodrigues"  # User name to use if no signature image
TEST_DATE = datetime.now()  # Current date

# Create a BatchProcessor instance to use its methods
processor = BatchProcessor(None)  # LLM service not needed for this test


def test_signature():
    """Test signature functionality."""
    # Load the template (which already has a signature table)
    print(f"Loading template: {TEMPLATE_PATH}")
    doc = Document(TEMPLATE_PATH)
    
    # Test with signature image
    print("\n" + "="*60)
    print("TEST 1: With Signature Image")
    print("="*60)
    
    # Use the actual batch_processor method
    processor._modify_existing_signature_table(
        doc, TEST_DATE, SIGNATURE_IMAGE_PATH, USER_NAME
    )
    
    # Save the document
    print(f"\nSaving document to: {OUTPUT_PATH}")
    output_dir = Path(OUTPUT_PATH).parent
    output_dir.mkdir(parents=True, exist_ok=True)
    
    doc.save(OUTPUT_PATH)
    print(f"[SUCCESS] Document saved successfully!")
    print(f"\nOpen {OUTPUT_PATH} to verify:")
    print("  1. Date is filled and underlined")
    print("  2. Signature image appears inline after 'Teacher Signature:'")
    
    # Test without signature image (user name only)
    print("\n" + "="*60)
    print("TEST 2: Without Signature Image (User Name Only)")
    print("="*60)
    doc2 = Document(TEMPLATE_PATH)
    output_path_no_image = "output/test_signature_no_image.docx"
    
    # Use the actual batch_processor method
    processor._modify_existing_signature_table(
        doc2, TEST_DATE, None, USER_NAME
    )
    
    output_dir = Path(output_path_no_image).parent
    output_dir.mkdir(parents=True, exist_ok=True)
    doc2.save(output_path_no_image)
    print(f"[SUCCESS] Document saved: {output_path_no_image}")
    
    print(f"\nOpen {output_path_no_image} to verify:")
    print("  1. Date is filled and underlined")
    print("  2. User name appears underlined after 'Teacher Signature:'")
    
    print("\n" + "="*60)
    print("[SUCCESS] All tests completed successfully!")
    print("="*60)


if __name__ == "__main__":
    test_signature()

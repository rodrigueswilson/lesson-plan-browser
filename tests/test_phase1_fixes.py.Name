"""
Test script for Phase 1 fixes:
1. Verify all lesson steps have non-zero durations
2. Verify instruction extraction from ell_support strategies
3. Test with real lesson data
"""

import sys
import json
from pathlib import Path

# Add backend to path
sys.path.insert(0, str(Path(__file__).parent / "backend"))

from backend.database import SQLiteDatabase
from backend.config import settings
from backend.api import generate_lesson_steps
from backend.models import LessonStepResponse
from fastapi import Request
from unittest.mock import Mock


def test_duration_fixes():
    """Test that all steps have non-zero durations."""
    print("\n" + "="*60)
    print("TEST 1: Duration Fixes")
    print("="*60)
    
    # You'll need to provide actual plan_id, day, and slot
    # For testing, you can use an existing lesson plan
    print("\nTo test duration fixes:")
    print("1. Find a lesson plan ID from your database")
    print("2. Identify a day and slot that has lesson steps")
    print("3. Run: python test_phase1_fixes.py --plan-id <ID> --day monday --slot 1")
    print("\nThe test will:")
    print("- Generate/regenerate lesson steps")
    print("- Check that all steps have duration_minutes > 0")
    print("- Report any steps with zero duration")
    
    return True


def test_instruction_extraction():
    """Test that instructions are extracted from ell_support."""
    print("\n" + "="*60)
    print("TEST 2: Instruction Extraction")
    print("="*60)
    
    print("\nTo test instruction extraction:")
    print("1. Ensure your lesson JSON has ell_support with:")
    print("   - strategy_id: 'cognate_awareness' or 'sentence_frames'")
    print("   - implementation field with instructional text")
    print("2. Generate lesson steps for a lesson with vocabulary/frames")
    print("3. Check that display_content includes the implementation text")
    
    return True


def verify_steps(plan_id: str, day: str, slot: int):
    """Verify generated steps meet Phase 1 requirements."""
    print("\n" + "="*60)
    print(f"VERIFYING STEPS: Plan {plan_id}, {day}, Slot {slot}")
    print("="*60)
    
    db = SQLiteDatabase()
    
    # Get existing steps
    steps = db.get_lesson_steps(plan_id, day_of_week=day, slot_number=slot)
    
    if not steps:
        print(f"\n⚠️  No steps found. Generating new steps...")
        # Generate steps
        # Note: This requires a mock request object
        # In practice, you'd call the API endpoint
        print("   Please use the API endpoint to generate steps first:")
        print(f"   POST /api/lesson-steps/generate?plan_id={plan_id}&day={day}&slot={slot}")
        return False
    
    print(f"\n✓ Found {len(steps)} steps")
    
    # Test 1: Check durations
    print("\n--- Checking Durations ---")
    zero_duration_steps = []
    for step in steps:
        if step.duration_minutes == 0:
            zero_duration_steps.append(step)
            print(f"  ❌ Step {step.step_number} '{step.step_name}': duration = 0")
        else:
            print(f"  ✓ Step {step.step_number} '{step.step_name}': {step.duration_minutes} min")
    
    if zero_duration_steps:
        print(f"\n⚠️  Found {len(zero_duration_steps)} steps with zero duration!")
        print("   These should be fixed by the Phase 1 changes.")
        print("   Try regenerating the steps.")
        return False
    else:
        print("\n✓ All steps have non-zero durations!")
    
    # Test 2: Check instruction extraction
    print("\n--- Checking Instruction Extraction ---")
    vocab_step = next((s for s in steps if "vocabulary" in s.step_name.lower() or "cognate" in s.step_name.lower()), None)
    frames_step = next((s for s in steps if "sentence frame" in s.step_name.lower() or s.content_type == "sentence_frames"), None)
    
    if vocab_step:
        print(f"\n  Vocabulary Step: '{vocab_step.step_name}'")
        if vocab_step.display_content and len(vocab_step.display_content) > 50:
            # Check if it starts with instructional text (not just word list)
            if not vocab_step.display_content.strip().startswith("-"):
                print(f"  ✓ Has instructional text ({len(vocab_step.display_content)} chars)")
                print(f"     Preview: {vocab_step.display_content[:100]}...")
            else:
                print(f"  ⚠️  Only has word list, no instructional text")
                print(f"     Content: {vocab_step.display_content[:100]}...")
        else:
            print(f"  ⚠️  Missing or very short display_content")
    else:
        print("\n  ℹ️  No vocabulary step found (may not have vocabulary_cognates)")
    
    if frames_step:
        print(f"\n  Sentence Frames Step: '{frames_step.step_name}'")
        if frames_step.display_content and len(frames_step.display_content) > 20:
            print(f"  ✓ Has instructional text ({len(frames_step.display_content)} chars)")
            print(f"     Preview: {frames_step.display_content[:100]}...")
        else:
            print(f"  ⚠️  Missing or very short display_content")
            print(f"     Content: {frames_step.display_content}")
    else:
        print("\n  ℹ️  No sentence frames step found (may not have sentence_frames)")
    
    # Summary
    print("\n" + "="*60)
    print("SUMMARY")
    print("="*60)
    print(f"Total steps: {len(steps)}")
    print(f"Steps with zero duration: {len(zero_duration_steps)}")
    print(f"Vocabulary step with instructions: {vocab_step and vocab_step.display_content and len(vocab_step.display_content) > 50}")
    print(f"Frames step with instructions: {frames_step and frames_step.display_content and len(frames_step.display_content) > 20}")
    
    return len(zero_duration_steps) == 0


def check_lesson_json_structure(plan_id: str):
    """Check if lesson JSON has the expected structure for instruction extraction."""
    print("\n" + "="*60)
    print(f"CHECKING LESSON JSON STRUCTURE: Plan {plan_id}")
    print("="*60)
    
    db = SQLiteDatabase()
    plan = db.get_weekly_plan(plan_id)
    
    if not plan:
        print(f"❌ Plan not found: {plan_id}")
        return False
    
    if not plan.lesson_json:
        print("❌ Plan has no lesson_json")
        return False
    
    lesson_json = plan.lesson_json
    if isinstance(lesson_json, str):
        lesson_json = json.loads(lesson_json)
    
    # Check for ell_support in tailored_instruction
    print("\n--- Checking for ell_support strategies ---")
    
    days = lesson_json.get("days", {})
    found_strategies = False
    
    for day_name, day_data in days.items():
        slots = day_data.get("slots", [])
        if not slots:
            # Check day-level
            tailored = day_data.get("tailored_instruction", {})
            ell_support = tailored.get("ell_support", [])
            if ell_support:
                print(f"\n  {day_name} (day-level):")
                found_strategies = True
                for s in ell_support:
                    strategy_id = s.get("strategy_id", "")
                    strategy_name = s.get("strategy_name", "")
                    has_implementation = bool(s.get("implementation"))
                    has_implementation_steps = bool(s.get("implementation_steps"))
                    print(f"    - {strategy_id or strategy_name}")
                    print(f"      implementation: {has_implementation}")
                    print(f"      implementation_steps: {has_implementation_steps}")
        else:
            # Check slot-level
            for slot in slots:
                tailored = slot.get("tailored_instruction", {})
                ell_support = tailored.get("ell_support", [])
                if ell_support:
                    slot_num = slot.get("slot_number", "?")
                    print(f"\n  {day_name}, Slot {slot_num}:")
                    found_strategies = True
                    for s in ell_support:
                        strategy_id = s.get("strategy_id", "")
                        strategy_name = s.get("strategy_name", "")
                        has_implementation = bool(s.get("implementation"))
                        has_implementation_steps = bool(s.get("implementation_steps"))
                        print(f"    - {strategy_id or strategy_name}")
                        print(f"      implementation: {has_implementation}")
                        print(f"      implementation_steps: {has_implementation_steps}")
    
    if not found_strategies:
        print("  ⚠️  No ell_support strategies found in lesson JSON")
        print("     Instruction extraction will not work without these")
    
    return found_strategies


if __name__ == "__main__":
    import argparse
    
    parser = argparse.ArgumentParser(description="Test Phase 1 fixes for lesson steps")
    parser.add_argument("--plan-id", help="Lesson plan ID to test")
    parser.add_argument("--day", help="Day of week (e.g., monday)")
    parser.add_argument("--slot", type=int, help="Slot number")
    parser.add_argument("--check-json", action="store_true", help="Check lesson JSON structure")
    
    args = parser.parse_args()
    
    if args.check_json and args.plan_id:
        check_lesson_json_structure(args.plan_id)
    elif args.plan_id and args.day and args.slot:
        verify_steps(args.plan_id, args.day, args.slot)
    else:
        print("Phase 1 Test Script")
        print("="*60)
        print("\nUsage:")
        print("  Check lesson JSON structure:")
        print("    python test_phase1_fixes.py --plan-id <ID> --check-json")
        print("\n  Verify generated steps:")
        print("    python test_phase1_fixes.py --plan-id <ID> --day monday --slot 1")
        print("\n  General test info:")
        test_duration_fixes()
        test_instruction_extraction()


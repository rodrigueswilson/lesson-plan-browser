#!/usr/bin/env python3
"""
Test script for objectives PDF generation with HTML + CSS layout control.

This script tests the new HTML + PDF approach with sample objectives data
and compares it to the existing DOCX generation.
"""

import json
import sys
from pathlib import Path
from datetime import datetime

# Add backend to path
sys.path.append(str(Path(__file__).parent / "backend"))

from backend.services.objectives_pdf_generator import ObjectivesPDFGenerator
from backend.services.objectives_printer import ObjectivesPrinter


def create_sample_lesson_json() -> dict:
    """Create sample lesson JSON with W47 objectives for testing."""
    return {
        "metadata": {
            "week_of": "11-17-11-21",
            "grade": "3",
            "subject": "ELA",
            "homeroom": "Room 15",
            "teacher_name": "Ms. Wilson"
        },
        "days": {
            "monday": {
                "unit_lesson": "Unit 3 Lesson 9: MEASURE TO FIND THE AREA",
                "objective": {
                    "content_objective": "Students will measure area using square units and understand that area is the measure of space inside a shape.",
                    "student_goal": "I will find the area of shapes using square units.",
                    "wida_objective": "Students will use language to describe and compare areas of different shapes using square units and mathematical vocabulary (ELD-MA.3-5.Describe.Speaking) by using visual supports, sentence frames, and bilingual glossaries appropriate for WIDA levels 2-4, producing oral descriptions that demonstrate understanding of area measurement and spatial relationships."
                },
                "anticipatory_set": {
                    "original_content": "Show different sized rectangles and ask students which would need more tiles to cover.",
                    "bilingual_bridge": "Preview key vocabulary: área/area, quadrado/square, medir/measure. Quick L1 connection: 'Qual sala tem mais espaço?' (Which room has more space?)"
                },
                "tailored_instruction": {
                    "original_content": "Model how to count square units to find area. Guide students through examples.",
                    "co_teaching_model": "One Teach, One Observe",
                    "ell_support": "Provide grid paper with labeled units. Use gestures for 'cover' and 'count'.",
                    "special_needs_support": "Provide larger grid squares. Use color coding for rows and columns.",
                    "materials": "Grid paper, square tiles, rulers"
                },
                "misconceptions": {
                    "predicted": ["Students may count perimeter instead of area", "Students may leave gaps when counting"],
                    "responses": ["Use colored tiles to show filled space vs. outline", "Model placing tiles edge to edge"]
                },
                "assessment": {
                    "original_content": "Observe students finding area of given shapes. Check for accurate counting.",
                    "bilingual_overlay": "Allow students to explain their thinking in preferred language. Focus on process over language."
                },
                "homework": {
                    "original_content": "Find the area of 3 rectangles at home using square units.",
                    "family_connection": "Discuss with family: 'Onde vemos área em casa?' (Where do we see area at home?)"
                }
            },
            "tuesday": {
                "unit_lesson": "Unit 3 Lesson 10: SOLVE AREA PROBLEMS",
                "objective": {
                    "content_objective": "Students will solve real-world problems involving area measurement using addition and multiplication strategies.",
                    "student_goal": "I will solve area problems using what I know about adding and multiplying.",
                    "wida_objective": "Students will use language to explain problem-solving strategies for area calculations using mathematical operations and vocabulary (ELD-MA.3-5.Explain.Writing) by using graphic organizers, bilingual word walls, and peer collaboration appropriate for WIDA levels 3-5, producing written explanations that demonstrate understanding of the relationship between area, addition, and multiplication."
                },
                "anticipatory_set": {
                    "original_content": "Present a real-world scenario: 'A garden needs to be covered with grass. How do we know how much grass to buy?'",
                    "bilingual_bridge": "Connect to home experiences: 'Como seus pais calculam quanto piso comprar?' (How do your parents calculate how much flooring to buy?)"
                },

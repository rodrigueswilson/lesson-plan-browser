"""Test using tab stops for BOTH Administrator and Teacher rows for perfect alignment."""

from docx import Document
from docx.shared import Inches, Pt
from docx.enum.text import WD_TAB_ALIGNMENT
from datetime import datetime

# Load template
doc = Document("input/Lesson Plan Template SY'25-26.docx")

# Find signature table
signature_table = None
for table in doc.tables:
    table_text = "\n".join([cell.text for row in table.rows for cell in row.cells])
    if "Required Signatures" in table_text:
        signature_table = table
        break

if not signature_table:
    print("Signature table not found!")
    exit(1)

print("=" * 80)
print("APPLYING TAB STOPS TO BOTH ROWS")
print("=" * 80)

# Tab position for "Date:" label (5.5 inches works best)
DATE_TAB_POSITION = Inches(5.5)

# Process Administrator row
for row in signature_table.rows:
    for cell in row.cells:
        for para in cell.paragraphs:
            para_text = para.text
            if "Administrator Signature:" in para_text:
                print("\n[ADMINISTRATOR ROW]")
                print(f"Original: {repr(para_text[:80])}")
                
                # Get font properties
                original_font_size = Pt(11)
                original_font_name = "Times New Roman"
                for run in para.runs:
                    if run.font.size:
                        original_font_size = run.font.size
                    if run.font.name:
                        original_font_name = run.font.name
                    break
                
                # Clear and rebuild with tab stop
                para.clear()
                
                # Add tab stop at 5.5 inches
                para.paragraph_format.tab_stops.add_tab_stop(DATE_TAB_POSITION, WD_TAB_ALIGNMENT.LEFT)
                
                # Add "Administrator Signature:" label
                admin_run = para.add_run("Administrator Signature: ")
                admin_run.font.bold = True
                admin_run.font.size = original_font_size
                admin_run.font.name = original_font_name
                
                # Add underscores as placeholder
                placeholder_run = para.add_run("_" * 49)
                placeholder_run.font.size = original_font_size
                placeholder_run.font.name = original_font_name
                
                # Add TAB character to jump to tab stop
                tab_run = para.add_run("\t")
                
                # Add Date label
                date_label_run = para.add_run("Date: ")
                date_label_run.font.bold = True
                date_label_run.font.size = original_font_size
                date_label_run.font.name = original_font_name
                
                # Add date placeholder
                date_placeholder_run = para.add_run("__________________")
                date_placeholder_run.font.size = original_font_size
                date_placeholder_run.font.name = original_font_name
                
                print(f"Modified: {repr(para.text[:80])}")
                print("✓ Tab stop added at 5.5 inches")
                break

# Process Teacher row
for row in signature_table.rows:
    for cell in row.cells:
        for para in cell.paragraphs:
            para_text = para.text
            if "Teacher Signature:" in para_text:
                print("\n[TEACHER ROW]")
                print(f"Original: {repr(para_text[:80])}")
                
                # Get font properties
                original_font_size = Pt(11)
                original_font_name = "Times New Roman"
                for run in para.runs:
                    if run.font.size:
                        original_font_size = run.font.size
                    if run.font.name:
                        original_font_name = run.font.name
                    break
                
                # Clear and rebuild with tab stop
                para.clear()
                
                # Add tab stop at 5.5 inches (SAME as Administrator)
                para.paragraph_format.tab_stops.add_tab_stop(DATE_TAB_POSITION, WD_TAB_ALIGNMENT.LEFT)
                
                # Add "Teacher Signature:" label
                teacher_run = para.add_run("Teacher Signature: ")
                teacher_run.font.bold = True
                teacher_run.font.size = original_font_size
                teacher_run.font.name = original_font_name
                
                # Add name
                name_run = para.add_run("Wilson Rodrigues")
                name_run.font.underline = True
                name_run.font.size = original_font_size
                name_run.font.name = original_font_name
                
                # Add TAB character to jump to tab stop (SAME position as Administrator)
                tab_run = para.add_run("\t")
                
                # Add Date label
                date_label_run = para.add_run("Date: ")
                date_label_run.font.bold = True
                date_label_run.font.size = original_font_size
                date_label_run.font.name = original_font_name
                
                # Add date value
                date_value_run = para.add_run(datetime.now().strftime("%m/%d/%Y"))
                date_value_run.font.underline = True
                date_value_run.font.size = original_font_size
                date_value_run.font.name = original_font_name
                
                print(f"Modified: {repr(para.text[:80])}")
                print("✓ Tab stop added at 5.5 inches (SAME as Administrator)")
                break

# Save test document
output_path = "output/test_tab_both_rows.docx"
doc.save(output_path)

print("\n" + "=" * 80)
print(f"[SUCCESS] Saved to: {output_path}")
print("=" * 80)
print("\nBoth rows now use tab stops at 5.5 inches")
print("The 'Date:' labels should be PERFECTLY aligned!")
print("\nOpen the document to verify alignment.")

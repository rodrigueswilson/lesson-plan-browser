#!/usr/bin/env python3
"""Test script to verify the lesson plan data fix"""

import requests
import json
import sys

# Test API endpoints
BASE_URL = "http://localhost:8000"

def test_lesson_api():
    """Test that the lesson API returns properly structured data"""
    
    # First get a list of plans to find a test plan ID
    try:
        response = requests.get(f"{BASE_URL}/api/plans?user_id=test_user&limit=10&requester_id=test_user")
        response.raise_for_status()
        plans = response.json()
        
        if not plans.get("data"):
            print("No plans found for test_user")
            return False
            
        # Use the first plan for testing
        test_plan = plans["data"][0]
        plan_id = test_plan["id"]
        week_of = test_plan["week_of"]
        
        print(f"Testing with plan: {plan_id} ({week_of})")
        
        # Test the lesson detail endpoint
        detail_response = requests.get(f"{BASE_URL}/api/plans/{plan_id}?user_id=test_user")
        detail_response.raise_for_status()
        plan_detail = detail_response.json()
        
        # Check the structure
        if "data" not in plan_detail:
            print("ERROR: Response missing 'data' wrapper")
            print("Response structure:", json.dumps(plan_detail, indent=2)[:500])
            return False
            
        lesson_data = plan_detail["data"]
        
        if "lesson_json" not in lesson_data:
            print("ERROR: lesson_json not found in data")
            return False
            
        lesson_json = lesson_data["lesson_json"]
        
        if not lesson_json or "days" not in lesson_json:
            print("ERROR: lesson_json is empty or missing days")
            return False
            
        # Count total slots
        total_slots = 0
        for day_name, day_data in lesson_json["days"].items():
            if "slots" in day_data and isinstance(day_data["slots"], list):
                total_slots += len(day_data["slots"])
                print(f"  {day_name}: {len(day_data['slots'])} slots")
        
        print(f"SUCCESS: Found {total_slots} total lesson slots")
        return True
        
    except requests.exceptions.RequestException as e:
        print(f"ERROR: API request failed: {e}")
        return False
    except json.JSONDecodeError as e:
        print(f"ERROR: Invalid JSON response: {e}")
        return False
    except Exception as e:
        print(f"ERROR: Unexpected error: {e}")
        return False

if __name__ == "__main__":
    print("Testing lesson plan API fix...")
    success = test_lesson_api()
    sys.exit(0 if success else 1)

"""
Test script for schedule API endpoints.
Run this after starting the backend server to verify schedule functionality.
"""

import requests
import json
from datetime import datetime

API_BASE_URL = "http://localhost:8000/api"

def test_schedule_api():
    """Test schedule API endpoints."""
    
    print("=" * 60)
    print("Testing Schedule API")
    print("=" * 60)
    
    # First, create or get a test user
    print("\n1. Creating/Getting test user...")
    try:
        # Try to get existing users
        response = requests.get(f"{API_BASE_URL}/users")
        if response.status_code == 200:
            users = response.json()
            if users:
                test_user_id = users[0]['id']
                print(f"   Using existing user: {test_user_id}")
            else:
                # Create new user
                response = requests.post(
                    f"{API_BASE_URL}/users",
                    json={"first_name": "Test", "last_name": "User", "email": "test@example.com"}
                )
                if response.status_code == 200:
                    test_user_id = response.json()['id']
                    print(f"   Created new user: {test_user_id}")
                else:
                    print(f"   Error creating user: {response.status_code} - {response.text}")
                    return
        else:
            print(f"   Error getting users: {response.status_code} - {response.text}")
            return
    except Exception as e:
        print(f"   Error: {e}")
        return
    
    # Set headers for authentication
    headers = {"X-Current-User-Id": test_user_id}
    
    # Test 2: Create a schedule entry
    print("\n2. Creating schedule entry...")
    test_entry = {
        "user_id": test_user_id,
        "day_of_week": "monday",
        "start_time": "08:30",
        "end_time": "09:15",
        "subject": "ELA",
        "homeroom": "T5",
        "grade": "5",
        "slot_number": 1,
        "is_active": True
    }
    
    try:
        response = requests.post(
            f"{API_BASE_URL}/schedules",
            json=test_entry,
            headers=headers
        )
        if response.status_code == 200:
            created_entry = response.json()
            schedule_id = created_entry['id']
            print(f"   Created entry: {schedule_id}")
            print(f"   Subject: {created_entry['subject']}, Grade: {created_entry['grade']}, Homeroom: {created_entry['homeroom']}")
        else:
            print(f"   Error creating entry: {response.status_code} - {response.text}")
            return
    except Exception as e:
        print(f"   Error: {e}")
        return
    
    # Test 3: Get schedule
    print("\n3. Getting schedule...")
    try:
        response = requests.get(
            f"{API_BASE_URL}/schedules/{test_user_id}",
            headers=headers
        )
        if response.status_code == 200:
            entries = response.json()
            print(f"   Found {len(entries)} schedule entries")
            for entry in entries[:3]:  # Show first 3
                print(f"   - {entry['day_of_week']}: {entry['start_time']}-{entry['end_time']} - {entry['subject']}")
        else:
            print(f"   Error getting schedule: {response.status_code} - {response.text}")
    except Exception as e:
        print(f"   Error: {e}")
    
    # Test 4: Test non-class period normalization
    print("\n4. Testing non-class period normalization...")
    prep_entry = {
        "user_id": test_user_id,
        "day_of_week": "monday",
        "start_time": "10:06",
        "end_time": "10:51",
        "subject": "PREP TIME",  # Should normalize to "PREP"
        "homeroom": "T5",  # Should be cleared
        "grade": "5",  # Should be cleared
        "slot_number": 2,
        "is_active": True
    }
    
    try:
        response = requests.post(
            f"{API_BASE_URL}/schedules",
            json=prep_entry,
            headers=headers
        )
        if response.status_code == 200:
            created_prep = response.json()
            print(f"   Created PREP entry:")
            print(f"   Subject: {created_prep['subject']} (should be 'PREP')")
            print(f"   Grade: {created_prep['grade']} (should be null)")
            print(f"   Homeroom: {created_prep['homeroom']} (should be null)")
            print(f"   Is Active: {created_prep['is_active']} (should be False)")
            
            if created_prep['subject'] == 'PREP' and created_prep['grade'] is None:
                print("   [OK] Normalization working correctly!")
            else:
                print("   [FAIL] Normalization failed!")
        else:
            print(f"   Error creating PREP entry: {response.status_code} - {response.text}")
    except Exception as e:
        print(f"   Error: {e}")
    
    # Test 5: Bulk create
    print("\n5. Testing bulk create...")
    bulk_entries = [
        {
            "user_id": test_user_id,
            "day_of_week": "tuesday",
            "start_time": "08:30",
            "end_time": "09:15",
            "subject": "MATH",
            "homeroom": "209",
            "grade": "5",
            "slot_number": 1,
        },
        {
            "user_id": test_user_id,
            "day_of_week": "tuesday",
            "start_time": "09:18",
            "end_time": "10:03",
            "subject": "SCIENCE",
            "homeroom": "T2",
            "grade": "2",
            "slot_number": 2,
        },
    ]
    
    try:
        response = requests.post(
            f"{API_BASE_URL}/schedules/{test_user_id}/bulk",
            json={"entries": bulk_entries},
            headers=headers
        )
        if response.status_code == 200:
            result = response.json()
            print(f"   Bulk created {result['created_count']} entries")
            if result.get('errors'):
                print(f"   Errors: {result['errors']}")
            else:
                print("   [OK] Bulk create successful!")
        else:
            print(f"   Error bulk creating: {response.status_code} - {response.text}")
    except Exception as e:
        print(f"   Error: {e}")
    
    # Test 6: Get current lesson (if during school hours)
    print("\n6. Testing get current lesson...")
    try:
        response = requests.get(
            f"{API_BASE_URL}/schedules/{test_user_id}/current",
            headers=headers
        )
        if response.status_code == 200:
            current = response.json()
            if current:
                print(f"   Current lesson: {current['subject']} at {current['start_time']}-{current['end_time']}")
            else:
                print("   No current lesson (outside school hours)")
        else:
            print(f"   Error getting current lesson: {response.status_code} - {response.text}")
    except Exception as e:
        print(f"   Error: {e}")
    
    print("\n" + "=" * 60)
    print("Test completed!")
    print("=" * 60)
    print(f"\nTest user ID: {test_user_id}")
    print("You can check the database or use the API to verify the entries were created.")


if __name__ == "__main__":
    try:
        # Check if server is running
        response = requests.get(f"{API_BASE_URL}/health", timeout=2)
        if response.status_code != 200:
            print("Error: Backend server is not running or not accessible")
            print("Please start the backend server first:")
            print("  python -m uvicorn backend.api:app --reload")
            exit(1)
    except Exception as e:
        print("Error: Could not connect to backend server")
        print("Please start the backend server first:")
        print("  python -m uvicorn backend.api:app --reload")
        exit(1)
    
    test_schedule_api()


"""Test using tab stops for precise alignment instead of spaces."""

from docx import Document
from docx.shared import Inches, Pt
from docx.enum.text import WD_TAB_ALIGNMENT
from datetime import datetime

# Load template
doc = Document("input/Lesson Plan Template SY'25-26.docx")

# Find signature table
signature_table = None
for table in doc.tables:
    table_text = "\n".join([cell.text for row in table.rows for cell in row.cells])
    if "Required Signatures" in table_text:
        signature_table = table
        break

if not signature_table:
    print("Signature table not found!")
    exit(1)

print("=" * 80)
print("ANALYZING ADMINISTRATOR ROW FOR TAB STOP POSITION")
print("=" * 80)

# First, analyze the Administrator row to find where Date: is positioned
admin_para = None
for row in signature_table.rows:
    for cell in row.cells:
        for para in cell.paragraphs:
            if "Administrator Signature:" in para.text:
                admin_para = para
                break

if admin_para:
    # Measure the cell width
    cell_width = admin_para._element.getparent().getparent().xpath('.//w:tcW/@w:w')
    print(f"Cell width (twips): {cell_width}")
    
    # Check existing tab stops
    print(f"\nExisting tab stops: {len(admin_para.paragraph_format.tab_stops)}")
    for i, tab_stop in enumerate(admin_para.paragraph_format.tab_stops):
        print(f"  Tab {i}: position={tab_stop.position} ({tab_stop.position.inches} inches), alignment={tab_stop.alignment}")

print("\n" + "=" * 80)
print("TESTING TAB STOP APPROACH ON TEACHER ROW")
print("=" * 80)

# Find Teacher Signature row
for row in signature_table.rows:
    for cell in row.cells:
        for para in cell.paragraphs:
            para_text = para.text
            if "Teacher Signature:" in para_text:
                print(f"\nOriginal text: {repr(para_text)}")
                
                # Get font properties
                original_font_size = Pt(11)
                original_font_name = "Calibri"
                for run in para.runs:
                    if run.font.size:
                        original_font_size = run.font.size
                    if run.font.name:
                        original_font_name = run.font.name
                    if original_font_size and original_font_name:
                        break
                
                print(f"Font: {original_font_name}, Size: {original_font_size.pt}pt")
                
                # Clear and rebuild with tab stop
                para.clear()
                
                # Add tab stop at the position where "Date:" should appear
                # Based on analysis: Administrator's Date: starts at position 74 characters
                # In a typical Word document with 11pt Calibri, this is approximately 5.2 inches
                # But we need to measure from the actual document
                
                # Let's use 5.2 inches as starting point (can be adjusted)
                tab_position = Inches(5.2)
                para.paragraph_format.tab_stops.add_tab_stop(tab_position, WD_TAB_ALIGNMENT.LEFT)
                
                print(f"Added tab stop at: {tab_position.inches} inches")
                
                # Rebuild the paragraph with tab character
                teacher_run = para.add_run("Teacher Signature: ")
                teacher_run.font.bold = True
                teacher_run.font.size = original_font_size
                teacher_run.font.name = original_font_name
                
                # Add name
                name_run = para.add_run("Wilson Rodrigues")
                name_run.font.underline = True
                name_run.font.size = original_font_size
                name_run.font.name = original_font_name
                
                # Add TAB character to jump to the tab stop position
                tab_run = para.add_run("\t")
                
                # Add Date label and value
                date_label_run = para.add_run("Date: ")
                date_label_run.font.bold = True
                date_label_run.font.size = original_font_size
                date_label_run.font.name = original_font_name
                
                date_value_run = para.add_run(datetime.now().strftime("%m/%d/%Y"))
                date_value_run.font.underline = True
                date_value_run.font.size = original_font_size
                date_value_run.font.name = original_font_name
                
                print(f"New text: {repr(para.text)}")
                print("Tab character inserted before 'Date:'")
                
                break

# Save test document
output_path = "output/test_tab_stops.docx"
doc.save(output_path)
print(f"\n{'=' * 80}")
print(f"[SUCCESS] Saved to: {output_path}")
print(f"{'=' * 80}")
print("\nOpen the document and check if 'Date:' labels are aligned!")

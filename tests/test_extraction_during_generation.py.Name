"""
Test if vocabulary_cognates is extracted correctly during step generation.
Simulate the exact extraction logic from generate_lesson_steps.
"""
import sys
import json
from pathlib import Path

sys.path.append(str(Path(__file__).parent))

from backend.database import get_db

plan_id = "plan_20251122160826"
db = get_db()

# Get plan and extract day/slot data (same as generate_lesson_steps)
plan = db.get_weekly_plan(plan_id)
lesson_json = plan.lesson_json
days = lesson_json.get("days", {})
day_data = days.get("monday")

if not day_data:
    print("[FAIL] Monday not found")
    sys.exit(1)

# Extract slot_data (same as generate_lesson_steps)
slot_data = day_data
slots_for_day = day_data.get("slots") or []

if isinstance(slots_for_day, list) and slots_for_day:
    matching = None
    for s in slots_for_day:
        if not isinstance(s, dict):
            continue
        s_num = s.get("slot_number", 0)
        if int(s_num) == int(1):  # slot = 1
            matching = s
            break
    
    if matching:
        slot_data = matching
    else:
        slot_data = slots_for_day[0]

# Extract vocabulary_cognates (EXACT same logic as line 2639-2643)
vocabulary_cognates = (
    slot_data.get("vocabulary_cognates")
    or day_data.get("vocabulary_cognates")
    or []
)

day_sentence_frames = (
    slot_data.get("sentence_frames") or day_data.get("sentence_frames") or []
)

print("="*80)
print("EXTRACTION TEST (Same logic as generate_lesson_steps)")
print("="*80)
print(f"\nSlot data has vocabulary_cognates: {'vocabulary_cognates' in slot_data}")
print(f"Slot data vocabulary_cognates value: {slot_data.get('vocabulary_cognates')}")
print(f"Day data has vocabulary_cognates: {'vocabulary_cognates' in day_data}")
print(f"Day data vocabulary_cognates value: {day_data.get('vocabulary_cognates')}")

print(f"\nExtracted vocabulary_cognates:")
print(f"  Type: {type(vocabulary_cognates)}")
print(f"  Is list: {isinstance(vocabulary_cognates, list)}")
print(f"  Length: {len(vocabulary_cognates) if isinstance(vocabulary_cognates, list) else 'N/A'}")
print(f"  Value: {vocabulary_cognates}")

print(f"\nExtracted day_sentence_frames:")
print(f"  Type: {type(day_sentence_frames)}")
print(f"  Is list: {isinstance(day_sentence_frames, list)}")
print(f"  Length: {len(day_sentence_frames) if isinstance(day_sentence_frames, list) else 'N/A'}")

# Test the condition check (line 2664)
print(f"\nCondition check 'if vocabulary_cognates': {bool(vocabulary_cognates)}")

if vocabulary_cognates:
    print(f"  [OK] Would create vocabulary step with {len(vocabulary_cognates)} items")
    
    # Simulate vocab_step creation (line 2709-2724)
    vocab_step = {
        "id": "test-id",
        "lesson_plan_id": plan_id,
        "day_of_week": "monday",
        "slot_number": 1,
        "step_number": 5,
        "step_name": "Vocabulary / Cognate Awareness",
        "duration_minutes": 5,
        "start_time_offset": 0,
        "content_type": "instruction",
        "display_content": "Test",
        "hidden_content": [],
        "sentence_frames": [],
        "materials_needed": [],
        "vocabulary_cognates": vocabulary_cognates,
    }
    
    print(f"\n  vocab_step['vocabulary_cognates']:")
    print(f"    Type: {type(vocab_step['vocabulary_cognates'])}")
    print(f"    Length: {len(vocab_step['vocabulary_cognates'])}")
    print(f"    Value: {vocab_step['vocabulary_cognates']}")
else:
    print(f"  [FAIL] Would NOT create vocabulary step (vocabulary_cognates is falsy)")

print("\n" + "="*80)


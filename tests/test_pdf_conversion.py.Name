#!/usr/bin/env python3
"""
Test script to verify PDF conversion functionality.
Tests both WeasyPrint and provides diagnostics if it fails.
"""

import sys
import os
from pathlib import Path
import tempfile

# Add backend to path
sys.path.append(str(Path(__file__).parent / "backend"))

from backend.database import SQLiteDatabase
from backend.services.objectives_pdf_generator import ObjectivesPDFGenerator


def check_weasyprint_installation():
    """Check if WeasyPrint is properly installed."""
    print("=" * 80)
    print("CHECKING WEASYPRINT INSTALLATION")
    print("=" * 80)
    print()
    
    try:
        import weasyprint
        print("✓ WeasyPrint module found")
        try:
            print(f"  Version: {weasyprint.__version__}")
        except:
            print("  Version: Unable to determine")
        
        # Try to create a simple PDF
        try:
            html_string = "<html><body><h1>Test</h1></body></html>"
            test_pdf = tempfile.NamedTemporaryFile(suffix='.pdf', delete=False)
            weasyprint.HTML(string=html_string).write_pdf(test_pdf.name)
            test_pdf.close()
            
            # Check if file was created
            if Path(test_pdf.name).exists():
                size = Path(test_pdf.name).stat().st_size
                print(f"✓ WeasyPrint can generate PDFs (test file: {size} bytes)")
                Path(test_pdf.name).unlink()  # Clean up
                return True
            else:
                print("✗ PDF file was not created")
                return False
                
        except Exception as e:
            print(f"✗ WeasyPrint failed to generate PDF: {e}")
            print("\nPossible solutions:")
            print("  1. Install via conda: conda install -c conda-forge weasyprint")
            print("  2. Install GTK+ dependencies for Windows")
            print("  3. Use a virtual environment instead of Anaconda")
            return False
            
    except (ImportError, OSError) as e:
        error_msg = str(e)
        
        if "cannot load library" in error_msg or "DLL" in error_msg or "0x7e" in error_msg:
            print(f"✗ WeasyPrint DLL/Library error (Windows issue)")
            print(f"  Error: {error_msg[:100]}...")
            print("\n" + "=" * 80)
            print("SOLUTIONS FOR WINDOWS DLL ISSUES:")
            print("=" * 80)
            print("\nOption 1: Install via Conda (RECOMMENDED)")
            print("  conda install -c conda-forge weasyprint")
            print("\nOption 2: Install GTK+ Runtime")
            print("  Download from: https://github.com/tschoonj/GTK-for-Windows-Runtime-Environment-Installer")
            print("  Then run: pip install --force-reinstall weasyprint")
            print("\nOption 3: Use Playwright instead (see investigation doc)")
            print("  pip install playwright")
            print("  playwright install chromium")
        else:
            print(f"✗ WeasyPrint not installed: {e}")
            print("\nInstall with: pip install weasyprint")
        
        return False


def test_objectives_pdf_conversion():
    """Test PDF conversion with real objectives data."""
    print("\n" + "=" * 80)
    print("TESTING OBJECTIVES PDF CONVERSION")
    print("=" * 80)
    print()
    
    # Get Wilson's data
    print("1. Loading lesson plan data...")
    db = SQLiteDatabase()
    wilson = db.get_user_by_name("Wilson Rodrigues")
    
    if not wilson:
        print("✗ Wilson Rodrigues not found in database")
        return False
    
    print(f"✓ Found user: {wilson.name}")
    
    plans = db.get_user_plans(wilson.id, limit=1)
    if not plans or not plans[0].lesson_json:
        print("✗ No lesson plans found")
        return False
    
    plan = plans[0]
    print(f"✓ Found lesson plan: Week {plan.week_of}")
    print()
    
    # Generate HTML
    print("2. Generating HTML...")
    generator = ObjectivesPDFGenerator()
    
    output_dir = Path(tempfile.gettempdir()) / "objectives_pdf_test"
    output_dir.mkdir(exist_ok=True)
    
    html_path = output_dir / f"test_objectives_{plan.week_of.replace('/', '-')}.html"
    
    try:
        generator.generate_html(plan.lesson_json, str(html_path), user_name=wilson.name)
        print(f"✓ HTML generated: {html_path}")
        
        # Check HTML file
        if html_path.exists():
            size = html_path.stat().st_size
            print(f"  File size: {size:,} bytes")
        else:
            print("✗ HTML file not found")
            return False
    except Exception as e:
        print(f"✗ HTML generation failed: {e}")
        return False
    
    print()
    
    # Convert to PDF
    print("3. Converting HTML to PDF...")
    pdf_path = output_dir / f"test_objectives_{plan.week_of.replace('/', '-')}.pdf"
    
    try:
        result_path = generator.convert_to_pdf(str(html_path), str(pdf_path))
        print(f"✓ PDF generated: {result_path}")
        
        # Check PDF file
        if Path(result_path).exists():
            size = Path(result_path).stat().st_size
            print(f"  File size: {size:,} bytes")
            
            # Verify it's a valid PDF
            with open(result_path, 'rb') as f:
                header = f.read(4)
                if header == b'%PDF':
                    print("✓ Valid PDF file (header verified)")
                else:
                    print("✗ Invalid PDF file (header check failed)")
                    return False
        else:
            print("✗ PDF file not found")
            return False
            
        print()
        print("=" * 80)
        print("✓✓✓ PDF CONVERSION SUCCESSFUL! ✓✓✓")
        print("=" * 80)
        print()
        print(f"HTML: {html_path}")
        print(f"PDF:  {pdf_path}")
        print()
        print("You can open these files to verify the output.")
        
        return True
        
    except ImportError as e:
        print(f"✗ WeasyPrint not installed: {e}")
        print()
        print("Install WeasyPrint:")
        print("  Option 1 (conda): conda install -c conda-forge weasyprint")
        print("  Option 2 (pip):   pip install weasyprint")
        return False
        
    except Exception as e:
        print(f"✗ PDF conversion failed: {e}")
        print()
        print("Common issues:")
        print("  - Windows DLL errors: Install GTK+ dependencies or use conda")
        print("  - Permission errors: Check write permissions in output directory")
        print("  - Memory errors: Try with a smaller lesson plan")
        return False


def test_generate_pdf_method():
    """Test the all-in-one generate_pdf method."""
    print("\n" + "=" * 80)
    print("TESTING GENERATE_PDF METHOD (HTML + PDF in one call)")
    print("=" * 80)
    print()
    
    # Get Wilson's data
    db = SQLiteDatabase()
    wilson = db.get_user_by_name("Wilson Rodrigues")
    plans = db.get_user_plans(wilson.id, limit=1)
    plan = plans[0]
    
    output_dir = Path(tempfile.gettempdir()) / "objectives_pdf_test"
    output_dir.mkdir(exist_ok=True)
    
    pdf_path = output_dir / f"test_objectives_direct_{plan.week_of.replace('/', '-')}.pdf"
    
    generator = ObjectivesPDFGenerator()
    
    try:
        result_path = generator.generate_pdf(
            plan.lesson_json,
            str(pdf_path),
            user_name=wilson.name,
            keep_html=True  # Keep HTML for inspection
        )
        
        print(f"✓ PDF generated: {result_path}")
        
        if Path(result_path).exists():
            size = Path(result_path).stat().st_size
            print(f"  File size: {size:,} bytes")
            print("✓ generate_pdf() method works correctly")
            return True
        else:
            print("✗ PDF file not found")
            return False
            
    except Exception as e:
        print(f"✗ generate_pdf() failed: {e}")
        return False


def main():
    """Run all PDF conversion tests."""
    print("\n")
    print("╔" + "=" * 78 + "╗")
    print("║" + " " * 20 + "PDF CONVERSION TEST SUITE" + " " * 33 + "║")
    print("╚" + "=" * 78 + "╝")
    print()
    
    results = []
    
    # Test 1: Check WeasyPrint installation
    results.append(("WeasyPrint Installation", check_weasyprint_installation()))
    
    # Test 2: Test objectives PDF conversion
    if results[0][1]:  # Only run if WeasyPrint is installed
        results.append(("Objectives PDF Conversion", test_objectives_pdf_conversion()))
        
        # Test 3: Test generate_pdf method
        if results[1][1]:  # Only run if conversion works
            results.append(("Generate PDF Method", test_generate_pdf_method()))
    else:
        print("\nSkipping PDF conversion tests (WeasyPrint not available)")
    
    # Summary
    print("\n" + "=" * 80)
    print("TEST SUMMARY")
    print("=" * 80)
    print()
    
    for test_name, passed in results:
        status = "✓ PASS" if passed else "✗ FAIL"
        print(f"{status}: {test_name}")
    
    print()
    
    all_passed = all(result[1] for result in results)
    
    if all_passed:
        print("=" * 80)
        print("✓✓✓ ALL TESTS PASSED ✓✓✓")
        print("=" * 80)
        print()
        print("Your PDF conversion is working correctly!")
        print("You can now use it in production.")
    else:
        print("=" * 80)
        print("✗✗✗ SOME TESTS FAILED ✗✗✗")
        print("=" * 80)
        print()
        print("Please review the errors above and:")
        print("1. Install WeasyPrint if not installed")
        print("2. Fix any DLL/dependency issues")
        print("3. Check file permissions")
    
    return all_passed


if __name__ == "__main__":
    success = main()
    sys.exit(0 if success else 1)

"""
Test if slot_data extraction is working correctly.
"""
import sys
import json
from pathlib import Path

sys.path.append(str(Path(__file__).parent))

from backend.database import get_db

plan_id = "plan_20251122160826"
db = get_db()

# Get plan
plan = db.get_weekly_plan(plan_id)
if not plan:
    print("[FAIL] Plan not found")
    exit(1)

lesson_json = plan.lesson_json
if not lesson_json:
    print("[FAIL] Plan has no lesson_json")
    exit(1)

# Extract day and slot data (same as in generate_lesson_steps)
days = lesson_json.get("days", {})
day_data = days.get("monday")

if not day_data:
    print("[FAIL] Monday not found")
    exit(1)

print(f"[OK] Monday data found")

# Extract slot data
slot_data = day_data
slots_for_day = day_data.get("slots") or []

if isinstance(slots_for_day, list) and slots_for_day:
    matching = None
    for s in slots_for_day:
        if not isinstance(s, dict):
            continue
        s_num = s.get("slot_number", 0)
        print(f"  Checking slot: {s_num} (type: {type(s_num)})")
        if int(s_num) == int(1):  # slot = 1
            matching = s
            print(f"  [OK] Found matching slot: {s_num}")
            break
    
    if matching:
        slot_data = matching
        print(f"\n[OK] Using matched slot_data: slot_number={slot_data.get('slot_number')}")
    else:
        slot_data = slots_for_day[0]
        print(f"\n[WARN] Slot 1 not found, using first slot: {slot_data.get('slot_number')}")

# Check vocabulary and sentence frames
vocabulary_cognates = (
    slot_data.get("vocabulary_cognates")
    or day_data.get("vocabulary_cognates")
    or []
)

sentence_frames = (
    slot_data.get("sentence_frames") or day_data.get("sentence_frames") or []
)

print(f"\nExtraction results:")
print(f"  vocabulary_cognates type: {type(vocabulary_cognates)}")
print(f"  vocabulary_cognates length: {len(vocabulary_cognates) if isinstance(vocabulary_cognates, list) else 'N/A'}")
print(f"  vocabulary_cognates value: {vocabulary_cognates}")

print(f"  sentence_frames type: {type(sentence_frames)}")
print(f"  sentence_frames length: {len(sentence_frames) if isinstance(sentence_frames, list) else 'N/A'}")
print(f"  sentence_frames value: {sentence_frames}")

print(f"\nSlot_data keys (first 20): {list(slot_data.keys())[:20]}")
print(f"Slot_data has vocabulary_cognates: {'vocabulary_cognates' in slot_data}")
print(f"Slot_data has sentence_frames: {'sentence_frames' in slot_data}")

if 'vocabulary_cognates' in slot_data:
    print(f"Slot_data.vocabulary_cognates = {slot_data['vocabulary_cognates']}")
if 'sentence_frames' in slot_data:
    print(f"Slot_data.sentence_frames = {slot_data['sentence_frames']}")


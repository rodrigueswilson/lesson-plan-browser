"""
Unit test for hyperlink filtering logic.
"""

print("=" * 70)
print("Unit Test: Hyperlink Filtering Logic")
print("=" * 70)

def test_hyperlink_filtering_logic():
    """Test the filtering logic directly with mock hyperlinks."""
    
    # Mock hyperlinks with different day_hints
    mock_hyperlinks = [
        {'text': 'Monday Link', 'url': 'https://monday.com', 'day_hint': 'monday'},
        {'text': 'Tuesday Link', 'url': 'https://tuesday.com', 'day_hint': 'tuesday'},
        {'text': 'Wednesday Link', 'url': 'https://wednesday.com', 'day_hint': 'wednesday'},
        {'text': 'Thursday Link', 'url': 'https://thursday.com', 'day_hint': 'thursday'},
        {'text': 'Friday Link', 'url': 'https://friday.com', 'day_hint': 'friday'},
        {'text': 'No Day Hint Link', 'url': 'https://noday.com', 'day_hint': None},
    ]
    
    # No School days (as returned from extract_subject_content_for_slot)
    no_school_days = ['THURSDAY', 'FRIDAY']
    
    print(f"\nMock hyperlinks: {len(mock_hyperlinks)}")
    print(f"No School days: {no_school_days}")
    
    # Show hyperlinks by day
    print("\nHyperlinks before filtering:")
    by_day = {}
    for h in mock_hyperlinks:
        day = h.get('day_hint', 'no_day_hint')
        if day not in by_day:
            by_day[day] = []
        by_day[day].append(h)
    
    for day, links in sorted(by_day.items(), key=lambda x: (x[0] is None, x[0] or '')):
        print(f"  {day}: {len(links)} hyperlink(s)")
        for link in links:
            print(f"    - {link['text']}")
    
    # Apply filtering logic (same as in batch_processor.py)
    no_school_days_normalized = {day.lower().strip() for day in no_school_days}
    filtered_hyperlinks = [
        h for h in mock_hyperlinks
        if not h.get('day_hint') or h.get('day_hint', '').lower().strip() not in no_school_days_normalized
    ]
    
    filtered_count = len(mock_hyperlinks) - len(filtered_hyperlinks)
    
    print(f"\nAfter filtering:")
    print(f"  Total: {len(mock_hyperlinks)} -> {len(filtered_hyperlinks)}")
    print(f"  Filtered out: {filtered_count}")
    
    # Show filtered hyperlinks by day
    print("\nRemaining hyperlinks by day:")
    filtered_by_day = {}
    for h in filtered_hyperlinks:
        day = h.get('day_hint', 'no_day_hint')
        if day not in filtered_by_day:
            filtered_by_day[day] = []
        filtered_by_day[day].append(h)
    
    for day, links in sorted(filtered_by_day.items(), key=lambda x: (x[0] is None, x[0] or '')):
        print(f"  {day}: {len(links)} hyperlink(s)")
        for link in links:
            print(f"    - {link['text']}")
    
    # Verify results
    print("\n" + "=" * 70)
    print("Verification:")
    print("=" * 70)
    
    # Check 1: Thursday hyperlinks should be filtered
    thursday_links = [h for h in filtered_hyperlinks if h.get('day_hint') and h.get('day_hint', '').lower() == 'thursday']
    if thursday_links:
        print(f"[FAIL] Found {len(thursday_links)} Thursday hyperlink(s) that should have been filtered")
        return False
    else:
        print("[PASS] No Thursday hyperlinks remain")
    
    # Check 2: Friday hyperlinks should be filtered
    friday_links = [h for h in filtered_hyperlinks if h.get('day_hint') and h.get('day_hint', '').lower() == 'friday']
    if friday_links:
        print(f"[FAIL] Found {len(friday_links)} Friday hyperlink(s) that should have been filtered")
        return False
    else:
        print("[PASS] No Friday hyperlinks remain")
    
    # Check 3: Monday-Wednesday hyperlinks should remain
    weekday_links = [h for h in filtered_hyperlinks if h.get('day_hint') and h.get('day_hint', '').lower() in ['monday', 'tuesday', 'wednesday']]
    expected_weekday_count = 3
    if len(weekday_links) != expected_weekday_count:
        print(f"[FAIL] Expected {expected_weekday_count} weekday hyperlinks, found {len(weekday_links)}")
        return False
    else:
        print(f"[PASS] {len(weekday_links)} weekday hyperlinks remain (Monday, Tuesday, Wednesday)")
    
    # Check 4: Hyperlinks without day_hint should remain
    no_hint_links = [h for h in filtered_hyperlinks if not h.get('day_hint')]
    expected_no_hint_count = 1
    if len(no_hint_links) != expected_no_hint_count:
        print(f"[FAIL] Expected {expected_no_hint_count} hyperlink(s) without day_hint, found {len(no_hint_links)}")
        return False
    else:
        print(f"[PASS] {len(no_hint_links)} hyperlink(s) without day_hint remain (preserved)")
    
    # Check 5: Case insensitivity
    print("\nTesting case insensitivity:")
    test_cases = [
        ('THURSDAY', 'thursday'),
        ('thursday', 'THURSDAY'),
        ('Thursday', 'thursday'),
        ('  thursday  ', 'thursday'),
    ]
    
    all_passed = True
    for day1, day2 in test_cases:
        normalized1 = day1.lower().strip()
        normalized2 = day2.lower().strip()
        match = normalized1 == normalized2
        if match:
            print(f"  [PASS] '{day1}' matches '{day2}'")
        else:
            print(f"  [FAIL] '{day1}' does not match '{day2}'")
            all_passed = False
    
    return all_passed

def test_edge_cases():
    """Test edge cases for filtering."""
    print("\n" + "=" * 70)
    print("Edge Cases Test")
    print("=" * 70)
    
    # Edge case 1: Empty hyperlinks list
    print("\nTest 1: Empty hyperlinks list")
    empty_hyperlinks = []
    no_school_days = ['THURSDAY', 'FRIDAY']
    no_school_days_normalized = {day.lower().strip() for day in no_school_days}
    filtered = [
        h for h in empty_hyperlinks
        if not h.get('day_hint') or h.get('day_hint', '').lower().strip() not in no_school_days_normalized
    ]
    if len(filtered) == 0:
        print("  [PASS] Empty list handled correctly")
    else:
        print(f"  [FAIL] Expected empty list, got {len(filtered)} items")
        return False
    
    # Edge case 2: No No School days
    print("\nTest 2: No No School days")
    mock_hyperlinks = [
        {'text': 'Monday Link', 'url': 'https://monday.com', 'day_hint': 'monday'},
        {'text': 'Friday Link', 'url': 'https://friday.com', 'day_hint': 'friday'},
    ]
    no_school_days = []
    no_school_days_normalized = {day.lower().strip() for day in no_school_days}
    filtered = [
        h for h in mock_hyperlinks
        if not h.get('day_hint') or h.get('day_hint', '').lower().strip() not in no_school_days_normalized
    ]
    if len(filtered) == len(mock_hyperlinks):
        print(f"  [PASS] All {len(filtered)} hyperlinks preserved when no No School days")
    else:
        print(f"  [FAIL] Expected {len(mock_hyperlinks)} hyperlinks, got {len(filtered)}")
        return False
    
    # Edge case 3: All days are No School
    print("\nTest 3: All days are No School")
    mock_hyperlinks = [
        {'text': 'Monday Link', 'url': 'https://monday.com', 'day_hint': 'monday'},
        {'text': 'Tuesday Link', 'url': 'https://tuesday.com', 'day_hint': 'tuesday'},
        {'text': 'No Day Hint Link', 'url': 'https://noday.com', 'day_hint': None},
    ]
    no_school_days = ['MONDAY', 'TUESDAY', 'WEDNESDAY', 'THURSDAY', 'FRIDAY']
    no_school_days_normalized = {day.lower().strip() for day in no_school_days}
    filtered = [
        h for h in mock_hyperlinks
        if not h.get('day_hint') or h.get('day_hint', '').lower().strip() not in no_school_days_normalized
    ]
    # Should preserve only the one without day_hint
    if len(filtered) == 1 and filtered[0]['text'] == 'No Day Hint Link':
        print(f"  [PASS] Only hyperlink without day_hint preserved")
    else:
        print(f"  [FAIL] Expected 1 hyperlink (no day_hint), got {len(filtered)}")
        return False
    
    return True

if __name__ == "__main__":
    print("\n")
    test1_passed = test_hyperlink_filtering_logic()
    test2_passed = test_edge_cases()
    
    print("\n" + "=" * 70)
    if test1_passed and test2_passed:
        print("ALL TESTS PASSED: Hyperlink filtering logic works correctly")
    else:
        print("SOME TESTS FAILED: Check output above")
    print("=" * 70)


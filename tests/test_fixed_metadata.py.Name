#!/usr/bin/env python3
"""
Test the fixed ObjectivesPDFGenerator with real lesson data.
"""

import json
import sys
from pathlib import Path
import tempfile

# Add backend to path
sys.path.append(str(Path(__file__).parent / "backend"))

from backend.services.objectives_pdf_generator import ObjectivesPDFGenerator


def test_real_world_scenarios():
    """Test with real-world lesson scenarios."""
    print("=" * 80)
    print("TESTING FIXED OBJECTIVES PDF GENERATOR - REAL WORLD SCENARIOS")
    print("=" * 80)
    print()
    
    # Scenario 1: Mixed subjects in one week (common in multi-slot plans)
    print("SCENARIO 1: Mixed Subjects Week")
    print("-" * 40)
    
    mixed_week_lesson = {
        "metadata": {
            "week_of": "11-17-11-21",
            "grade": "3",
            "subject": "ELA / Math",  # Multi-subject metadata
            "homeroom": "Room 15",
            "teacher_name": "Ms. Wilson"
        },
        "days": {
            "monday": {
                "unit_lesson": "Unit 3 Lesson 9: MEASURE TO FIND THE AREA",
                "objective": {
                    "content_objective": "Students will measure area using square units and understand that area is the measure of space inside a shape.",
                    "student_goal": "I will find the area of shapes using square units.",
                    "wida_objective": "Students will use language to describe and compare areas of different shapes using square units and mathematical vocabulary."
                }
            },
            "tuesday": {
                "unit_lesson": "ELA Unit 2: READING COMPREHENSION STRATEGIES",
                "objective": {
                    "content_objective": "Students will apply reading comprehension strategies to understand grade-level texts.",
                    "student_goal": "I will use strategies to understand what I read.",
                    "wida_objective": "Students will use academic language to describe reading strategies and comprehension."
                }
            },
            "wednesday": {
                "unit_lesson": "Math Chapter 5: MULTIPLICATION FACTS TO 12",
                "objective": {
                    "content_objective": "Students will memorize multiplication facts up to 12x12 using patterns and strategies.",
                    "student_goal": "I will memorize my multiplication facts.",
                    "wida_objective": "Students will use mathematical language to state multiplication facts and explain patterns."
                }
            }
        }
    }
    
    generator = ObjectivesPDFGenerator()
    objectives = generator.extract_objectives(mixed_week_lesson)
    
    print(f"Extracted {len(objectives)} objectives:")
    for i, obj in enumerate(objectives, 1):
        print(f"  {i}. {obj['day']}: {obj['subject']}")
        print(f"     Unit: {obj['unit_lesson'][:50]}...")
        print(f"     Student Goal: {obj['student_goal']}")
        print()
    
    # Verify the subjects match the content
    print("Verification:")
    validations = [
        ("Monday Math content", objectives[0]['subject'] == 'Math', objectives[0]['subject']),
        ("Tuesday ELA content", objectives[1]['subject'] == 'ELA', objectives[1]['subject']),
        ("Wednesday Math content", objectives[2]['subject'] == 'Math', objectives[2]['subject'])
    ]
    
    all_correct = True
    for desc, is_correct, actual in validations:
        status = "✓" if is_correct else "✗"
        print(f"  {status} {desc}: {actual}")
        if not is_correct:
            all_correct = False
    
    print()
    
    # Scenario 2: Generate actual HTML to see headers
    print("SCENARIO 2: HTML Header Generation")
    print("-" * 40)
    
    try:
        with tempfile.NamedTemporaryFile(mode='w', suffix='.html', delete=False) as f:
            temp_path = f.name
        
        # Generate HTML
        generator.generate_html(mixed_week_lesson, temp_path, user_name="Ms. Wilson")
        
        # Read and extract headers
        with open(temp_path, 'r') as f:
            html_content = f.read()
        
        import re
        headers = re.findall(r'<div class="header">(.*?)</div>', html_content, re.DOTALL)
        
        print("Generated HTML headers (should now match content):")
        for i, header in enumerate(headers, 1):
            # Clean up HTML for display
            clean_header = header.replace('<br>', ' | ').strip()
            print(f"  {i}. {clean_header}")
        
        # Verify headers match the detected subjects
        print("\nHeader validation:")
        for i, (header, obj) in enumerate(zip(headers, objectives), 1):
            if obj['subject'] in header:
                print(f"  ✓ Header {i} contains correct subject: {obj['subject']}")
            else:
                print(f"  ✗ Header {i} mismatch. Expected {obj['subject']}, got: {header}")
                all_correct = False
        
        # Clean up
        Path(temp_path).unlink()
        
    except Exception as e:
        print(f"Could not generate HTML: {e}")
    
    print()
    
    # Scenario 3: Edge cases
    print("SCENARIO 3: Edge Cases")
    print("-" * 40)
    
    edge_cases = [
        ("No subject keywords", "Unit 5: DAILY ACTIVITIES", "Unknown"),
        ("Social Studies", "History Chapter 3: COMMUNITIES", "Social Studies"),
        ("Science", "Lab Report: PLANT GROWTH OBSERVATION", "Science"),
        ("Technology", "Computer Skills: TYPING PRACTICE", "Technology"),
        ("Physical Education", "PE Class: SOCCER DRILLS", "Physical Education")
    ]
    
    print("Subject detection for edge cases:")
    for description, unit_lesson, expected in edge_cases:
        from backend.services.objectives_pdf_generator import extract_subject_from_unit_lesson
        detected = extract_subject_from_unit_lesson(unit_lesson)
        status = "✓" if detected == expected else "✗"
        print(f"  {status} {description}: {detected} (expected: {expected})")
        if detected != expected:
            all_correct = False
    
    print()
    print("=" * 80)
    
    if all_correct:
        print("✓ ALL TESTS PASSED - FIX IS WORKING CORRECTLY!")
    else:
        print("✗ Some tests failed - fix needs adjustment")
    
    print("=" * 80)
    print()
    print("SUMMARY OF THE FIX:")
    print("-" * 40)
    print("1. Added extract_subject_from_unit_lesson() function")
    print("2. Function detects subject from unit_lesson text using:")
    print("   - Explicit subject prefixes (Math, ELA, Science, etc.)")
    print("   - Subject-specific keywords (area, reading, experiment, etc.)")
    print("3. Updated extract_objectives() to use detected subject")
    print("4. Falls back to metadata if detection fails")
    print("5. Headers now correctly match the actual lesson content")


if __name__ == "__main__":
    test_real_world_scenarios()

"""
Synthetic test to verify hyperlink filtering works when hyperlinks exist in No School days.
"""

from pathlib import Path
from docx import Document
from tools.docx_parser import DOCXParser
import tempfile
import os

print("=" * 70)
print("Synthetic Test: Hyperlink Filtering with No School Days")
print("=" * 70)

# Create a test document with hyperlinks in No School days
def create_test_doc_with_no_school_hyperlinks():
    """Create a test document with hyperlinks in No School day columns."""
    doc = Document()
    
    # Slot 1: Metadata table
    meta = doc.add_table(rows=3, cols=2)
    meta.rows[0].cells[0].text = "Name: Test Teacher"
    meta.rows[1].cells[0].text = "Subject: Math"
    meta.rows[1].cells[1].text = "Grade: 3"
    
    # Slot 1: Daily plans table with hyperlinks
    daily = doc.add_table(rows=4, cols=6)
    # Headers
    daily.rows[0].cells[0].text = "Day"
    daily.rows[0].cells[1].text = "Monday"
    daily.rows[0].cells[2].text = "Tuesday"
    daily.rows[0].cells[3].text = "Wednesday"
    daily.rows[0].cells[4].text = "Thursday"
    daily.rows[0].cells[5].text = "Friday"
    
    # Unit/Lesson row
    daily.rows[1].cells[0].text = "Unit, Lesson #"
    daily.rows[1].cells[1].text = "Unit 1, Lesson 1"
    daily.rows[1].cells[2].text = "Unit 1, Lesson 2"
    daily.rows[1].cells[3].text = "Unit 1, Lesson 3"
    daily.rows[1].cells[4].text = "No School"
    daily.rows[1].cells[5].text = "No School"
    
    # Objective row - with hyperlinks
    daily.rows[2].cells[0].text = "Objective"
    daily.rows[2].cells[1].text = "Learn addition"
    daily.rows[2].cells[2].text = "Learn subtraction"
    daily.rows[2].cells[3].text = "Learn multiplication"
    daily.rows[2].cells[4].text = "No School"
    daily.rows[2].cells[5].text = "No School"
    
    # Add hyperlinks to Monday, Wednesday, Thursday, Friday
    # Monday hyperlink
    monday_para = daily.rows[2].cells[1].paragraphs[0]
    run = monday_para.add_run("Check this link: ")
    add_part = run._element.getparent().getparent()
    hyperlink = add_part.xpath('.//w:p')[0].add_hyperlink(
        'https://monday-link.com', 'Monday Link', monday_para._element
    )
    
    # Wednesday hyperlink
    wednesday_para = daily.rows[2].cells[3].paragraphs[0]
    run = wednesday_para.add_run("Check this link: ")
    add_part = run._element.getparent().getparent()
    hyperlink = add_part.xpath('.//w:p')[0].add_hyperlink(
        'https://wednesday-link.com', 'Wednesday Link', wednesday_para._element
    )
    
    # Thursday hyperlink (No School day)
    thursday_para = daily.rows[2].cells[4].paragraphs[0]
    run = thursday_para.add_run("Check this link: ")
    add_part = run._element.getparent().getparent()
    hyperlink = add_part.xpath('.//w:p')[0].add_hyperlink(
        'https://thursday-link.com', 'Thursday Link', thursday_para._element
    )
    
    # Friday hyperlink (No School day)
    friday_para = daily.rows[2].cells[5].paragraphs[0]
    run = friday_para.add_run("Check this link: ")
    add_part = run._element.getparent().getparent()
    hyperlink = add_part.xpath('.//w:p')[0].add_hyperlink(
        'https://friday-link.com', 'Friday Link', friday_para._element
    )
    
    # Signature table
    sig = doc.add_table(rows=2, cols=2)
    sig.rows[0].cells[0].text = "Signature"
    
    # Save to temp file
    temp_dir = tempfile.mkdtemp()
    temp_file = os.path.join(temp_dir, "test_no_school_hyperlinks.docx")
    doc.save(temp_file)
    
    return temp_file

def test_filtering_with_synthetic_data():
    """Test filtering with a document that has hyperlinks in No School days."""
    print("\n" + "=" * 70)
    print("Creating synthetic test document...")
    
    test_file = create_test_doc_with_no_school_hyperlinks()
    print(f"Created test file: {test_file}")
    
    try:
        parser = DOCXParser(test_file)
        
        # Extract content
        content = parser.extract_subject_content_for_slot(1, "Math")
        no_school_days = content.get('no_school_days', [])
        
        print(f"\nNo School days detected: {no_school_days}")
        
        # Extract hyperlinks
        hyperlinks = parser.extract_hyperlinks_for_slot(1, "Math")
        print(f"Total hyperlinks extracted: {len(hyperlinks)}")
        
        # Group by day_hint
        by_day = {}
        no_day_hint = []
        for h in hyperlinks:
            day_hint = h.get('day_hint')
            if day_hint:
                day_normalized = day_hint.lower().strip()
                if day_normalized not in by_day:
                    by_day[day_normalized] = []
                by_day[day_normalized].append(h)
            else:
                no_day_hint.append(h)
        
        print("\nHyperlinks before filtering:")
        for day, links in sorted(by_day.items()):
            print(f"  {day}: {len(links)} hyperlink(s)")
            for link in links:
                print(f"    - {link.get('text', '')[:50]} ({link.get('url', '')[:50]})")
        if no_day_hint:
            print(f"  (no day_hint): {len(no_day_hint)} hyperlink(s)")
        
        # Apply filtering logic
        if no_school_days:
            no_school_days_normalized = {day.lower().strip() for day in no_school_days}
            print(f"\nFiltering hyperlinks from days: {no_school_days_normalized}")
            
            filtered_hyperlinks = [
                h for h in hyperlinks
                if not h.get('day_hint') or h.get('day_hint', '').lower().strip() not in no_school_days_normalized
            ]
            
            filtered_count = len(hyperlinks) - len(filtered_hyperlinks)
            print(f"\nAfter filtering:")
            print(f"  Total: {len(hyperlinks)} -> {len(filtered_hyperlinks)}")
            print(f"  Filtered out: {filtered_count}")
            
            # Group filtered hyperlinks by day
            filtered_by_day = {}
            for h in filtered_hyperlinks:
                day_hint = h.get('day_hint')
                if day_hint:
                    day_normalized = day_hint.lower().strip()
                    if day_normalized not in filtered_by_day:
                        filtered_by_day[day_normalized] = []
                    filtered_by_day[day_normalized].append(h)
            
            print("\nRemaining hyperlinks by day:")
            for day, links in sorted(filtered_by_day.items()):
                print(f"  {day}: {len(links)} hyperlink(s)")
                for link in links:
                    print(f"    - {link.get('text', '')[:50]} ({link.get('url', '')[:50]})")
            
            # Verify no hyperlinks from No School days remain
            remaining_no_school = []
            for day in no_school_days_normalized:
                if day in filtered_by_day:
                    remaining_no_school.extend(filtered_by_day[day])
            
            if remaining_no_school:
                print(f"\n[FAIL] Found {len(remaining_no_school)} hyperlinks from No School days still present!")
                for h in remaining_no_school:
                    print(f"  - {h.get('text', '')[:50]} (day: {h.get('day_hint')})")
                return False
            else:
                print(f"\n[PASS] All hyperlinks from No School days were filtered out correctly")
                
                # Verify expected hyperlinks remain
                expected_days = {'monday', 'wednesday'}  # Should have hyperlinks
                missing_days = []
                for day in expected_days:
                    if day not in filtered_by_day:
                        missing_days.append(day)
                
                if missing_days:
                    print(f"[WARNING] Expected hyperlinks missing from: {missing_days}")
                else:
                    print(f"[PASS] Expected hyperlinks remain (Monday, Wednesday)")
                
                return True
        else:
            print("\n[SKIP] No No School days detected in test document")
            return False
            
    except Exception as e:
        print(f"\n[ERROR] {e}")
        import traceback
        traceback.print_exc()
        return False
    finally:
        # Cleanup
        try:
            os.remove(test_file)
            os.rmdir(os.path.dirname(test_file))
        except:
            pass

if __name__ == "__main__":
    success = test_filtering_with_synthetic_data()
    
    print("\n" + "=" * 70)
    if success:
        print("TEST PASSED: Hyperlink filtering works correctly")
    else:
        print("TEST FAILED: Check output above")
    print("=" * 70)


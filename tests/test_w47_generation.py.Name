"""
Test script to generate lesson plan for Wilson Rodrigues, Week 47
Logs all errors for later fixing
"""

import requests
import json
import sys
from datetime import datetime

API_BASE_URL = "http://localhost:8000/api"
ERROR_LOG = []

def log_error(context, error):
    """Log an error with context"""
    error_entry = {
        "timestamp": datetime.now().isoformat(),
        "context": context,
        "error": str(error),
        "type": type(error).__name__
    }
    ERROR_LOG.append(error_entry)
    print(f"ERROR [{context}]: {error}", file=sys.stderr)

def get_users():
    """Get all users to find Wilson Rodrigues"""
    try:
        response = requests.get(f"{API_BASE_URL}/users")
        response.raise_for_status()
        users = response.json()
        print(f"Found {len(users)} users")
        return users
    except Exception as e:
        log_error("get_users", e)
        return []

def find_wilson_rodrigues(users):
    """Find Wilson Rodrigues user"""
    for user in users:
        name = f"{user.get('first_name', '')} {user.get('last_name', '')}".strip()
        if 'wilson' in name.lower() and 'rodrigues' in name.lower():
            print(f"Found Wilson Rodrigues: {user['id']} - {name}")
            return user
    log_error("find_wilson_rodrigues", "User not found")
    return None

def get_user_slots(user_id):
    """Get slots for the user"""
    try:
        response = requests.get(f"{API_BASE_URL}/users/{user_id}/slots")
        response.raise_for_status()
        slots = response.json()
        print(f"Found {len(slots)} slots for user")
        return slots
    except Exception as e:
        log_error("get_user_slots", e)
        return []

def generate_lesson_plan(user_id, week_of, slot_ids=None):
    """Generate lesson plan for the user and week"""
    try:
        payload = {
            "user_id": user_id,
            "week_of": week_of,
            "provider": "openai",
            "slot_ids": slot_ids or []
        }
        print(f"Generating lesson plan for week: {week_of}")
        print(f"Payload: {json.dumps(payload, indent=2)}")
        
        response = requests.post(
            f"{API_BASE_URL}/process-week",
            json=payload,
            headers={"Content-Type": "application/json"}
        )
        
        if response.status_code != 200:
            log_error("generate_lesson_plan", f"HTTP {response.status_code}: {response.text}")
            return None
        
        result = response.json()
        print(f"Generation started: {json.dumps(result, indent=2)}")
        return result
    except Exception as e:
        log_error("generate_lesson_plan", e)
        return None

def check_progress(plan_id):
    """Check progress of lesson plan generation"""
    try:
        response = requests.get(f"{API_BASE_URL}/progress/{plan_id}/poll")
        response.raise_for_status()
        return response.json()
    except Exception as e:
        log_error("check_progress", e)
        return None

def main():
    print("=" * 60)
    print("Testing Lesson Plan Generation for Wilson Rodrigues - Week 47")
    print("=" * 60)
    
    # Step 1: Get users
    print("\n1. Getting users...")
    users = get_users()
    if not users:
        print("ERROR: Could not retrieve users")
        return
    
    # Step 2: Find Wilson Rodrigues
    print("\n2. Finding Wilson Rodrigues...")
    user = find_wilson_rodrigues(users)
    if not user:
        print("ERROR: Wilson Rodrigues not found")
        return
    
    user_id = user['id']
    print(f"User ID: {user_id}")
    
    # Step 3: Get slots
    print("\n3. Getting user slots...")
    slots = get_user_slots(user_id)
    if not slots:
        print("WARNING: No slots found for user")
    
    slot_ids = [slot['id'] for slot in slots] if slots else []
    print(f"Slot IDs: {slot_ids}")
    
    # Step 4: Generate lesson plan for W47
    # Week format might be "2024-W47" or "W47" - need to check
    week_of = "W47"  # Try this format first
    print(f"\n4. Generating lesson plan for week: {week_of}")
    
    result = generate_lesson_plan(user_id, week_of, slot_ids)
    
    if result and result.get('plan_id'):
        plan_id = result['plan_id']
        print(f"\n5. Monitoring progress for plan: {plan_id}")
        
        # Poll progress a few times
        for i in range(10):
            import time
            time.sleep(2)
            progress = check_progress(plan_id)
            if progress:
                print(f"Progress update {i+1}: {json.dumps(progress, indent=2)}")
                if progress.get('status') in ['completed', 'complete', 'failed', 'error']:
                    break
    
    # Save error log
    if ERROR_LOG:
        with open("w47_generation_errors.json", "w") as f:
            json.dump(ERROR_LOG, f, indent=2)
        print(f"\n{len(ERROR_LOG)} errors logged to w47_generation_errors.json")
    else:
        print("\nNo errors encountered!")
    
    print("\n" + "=" * 60)
    print("Test completed")
    print("=" * 60)

if __name__ == "__main__":
    main()


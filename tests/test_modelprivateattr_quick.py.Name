"""
Quick test script to verify ModelPrivateAttr fixes.

Run this with: python test_modelprivateattr_quick.py

This test verifies:
1. Slot conversion from SQLModel to dictionary works
2. lesson_json conversion from Pydantic to dictionary works
3. 'in' operator checks work safely
4. Hyperlink/image iteration works safely
"""

import sys
from pathlib import Path

# Add project root to path
sys.path.insert(0, str(Path(__file__).parent))

# Mock objects to simulate SQLModel/Pydantic
class MockSQLModel:
    """Mock SQLModel object."""
    def __init__(self, **kwargs):
        self.__dict__.update(kwargs)
    
    def model_dump(self, mode='python'):
        return {k: v for k, v in self.__dict__.items() if not k.startswith('_')}
    
    def dict(self):
        return self.model_dump()


class MockLessonJSON:
    """Mock Pydantic lesson_json object."""
    def __init__(self, **kwargs):
        self.__dict__.update(kwargs)
    
    def model_dump(self, mode='python'):
        return {k: v for k, v in self.__dict__.items()}
    
    def dict(self):
        return self.model_dump()


def test_slot_conversion():
    """Test slot conversion to dictionary."""
    print("Test 1: Slot conversion...")
    
    mock_slot = MockSQLModel(
        id="test-id",
        slot_number=5,
        subject="Math",
        grade="5th",
    )
    
    # Simulate conversion logic from batch_processor
    if hasattr(mock_slot, "model_dump"):
        slot_dict = mock_slot.model_dump(mode='python')
    elif hasattr(mock_slot, "dict"):
        slot_dict = mock_slot.dict()
    else:
        slot_dict = dict(mock_slot)
    
    # Test safe access
    assert isinstance(slot_dict, dict), "Slot should be converted to dict"
    assert slot_dict.get("slot_number") == 5, "Should access slot_number via .get()"
    
    # Test 'in' operator (this should NOT raise ModelPrivateAttr error)
    try:
        if "grade" in slot_dict:
            assert slot_dict["grade"] == "5th"
        print("   [PASS] Slot conversion works correctly")
    except TypeError as e:
        if "ModelPrivateAttr" in str(e) or "not iterable" in str(e):
            print(f"   ✗ ModelPrivateAttr error: {e}")
            return False
        raise


def test_lesson_json_conversion():
    """Test lesson_json conversion to dictionary."""
    print("Test 2: lesson_json conversion...")
    
    mock_lesson_json = MockLessonJSON(
        days={"monday": {"unit_lesson": "Unit 1"}},
        metadata={"subject": "Math"},
        _hyperlinks=[{"text": "Link", "url": "http://example.com"}],
    )
    
    # Simulate conversion logic from batch_processor (line ~1195)
    if not isinstance(mock_lesson_json, dict):
        if hasattr(mock_lesson_json, "model_dump"):
            lesson_json = mock_lesson_json.model_dump(mode='python')
        elif hasattr(mock_lesson_json, "dict"):
            lesson_json = mock_lesson_json.dict()
        else:
            lesson_json = dict(mock_lesson_json) if mock_lesson_json else {}
    else:
        lesson_json = mock_lesson_json
    
    # Test 'in' operator checks (this should NOT raise ModelPrivateAttr error)
    try:
        if "metadata" not in lesson_json:
            lesson_json["metadata"] = {}
        if "_hyperlinks" in lesson_json:
            assert len(lesson_json["_hyperlinks"]) == 1
        print("   [PASS] lesson_json conversion works correctly")
    except TypeError as e:
        if "ModelPrivateAttr" in str(e) or "not iterable" in str(e):
            print(f"   ✗ ModelPrivateAttr error: {e}")
            return False
        raise


def test_hyperlinks_iteration():
    """Test safe hyperlink iteration."""
    print("Test 3: Hyperlink iteration...")
    
    lesson_json = {
        "_hyperlinks": [
            {"text": "Link 1", "url": "http://example.com/1"},
            {"text": "Link 2", "url": "http://example.com/2"},
        ],
        "_images": [],
    }
    
    # Simulate iteration logic from batch_processor
    try:
        if "_hyperlinks" in lesson_json:
            for link in lesson_json.get("_hyperlinks", []):
                if isinstance(link, dict):
                    link["_source_slot"] = 5
                    link["_source_subject"] = "Math"
        
        assert lesson_json["_hyperlinks"][0]["_source_slot"] == 5
        print("   [PASS] Hyperlink iteration works correctly")
    except TypeError as e:
        if "ModelPrivateAttr" in str(e) or "not iterable" in str(e):
            print(f"   ✗ ModelPrivateAttr error: {e}")
            return False
        raise


def test_slot_filtering():
    """Test slot ID filtering with set conversion."""
    print("Test 4: Slot filtering...")
    
    slots = [
        {"id": "slot-1", "slot_number": 1, "subject": "ELA"},
        {"id": "slot-2", "slot_number": 2, "subject": "Math"},
    ]
    
    slot_ids = ["slot-1"]
    slot_ids_set = set(slot_ids)
    
    # Filter slots (simulating batch_processor logic)
    filtered = [slot for slot in slots if slot.get("id") in slot_ids_set]
    
    assert len(filtered) == 1
    assert filtered[0]["id"] == "slot-1"
    print("   [PASS] Slot filtering works correctly")


def test_safe_access_patterns():
    """Test safe access patterns using .get() instead of 'in'."""
    print("Test 5: Safe access patterns...")
    
    slot = {"slot_number": 5, "subject": "Math"}
    
    # Use .get() instead of 'in' operator (safer pattern)
    if slot.get("grade"):
        grade = slot["grade"]
    else:
        grade = None
    
    assert grade is None  # grade doesn't exist
    
    if slot.get("subject"):
        subject = slot["subject"]
        assert subject == "Math"
    
    print("   [PASS] Safe access patterns work correctly")


def test_schedule_entry_conversion():
    """Test schedule entry conversion."""
    print("Test 6: Schedule entry conversion...")
    
    mock_entry = MockSQLModel(
        slot_number=5,
        is_active=True,
        start_time="09:00",
        end_time="10:00",
    )
    
    # Simulate conversion logic
    if hasattr(mock_entry, "model_dump"):
        entry_dict = mock_entry.model_dump()
    elif hasattr(mock_entry, "dict"):
        entry_dict = mock_entry.dict()
    else:
        entry_dict = {
            "slot_number": getattr(mock_entry, "slot_number", None),
            "is_active": getattr(mock_entry, "is_active", True),
            "start_time": getattr(mock_entry, "start_time", None),
            "end_time": getattr(mock_entry, "end_time", None),
        }
    
    assert isinstance(entry_dict, dict)
    assert entry_dict.get("slot_number") == 5
    
    # Test matching logic
    slot = {"slot_number": 5}
    matching = (
        entry_dict.get("slot_number") == slot.get("slot_number")
        and entry_dict.get("is_active", True)
    )
    assert matching is True
    print("   [PASS] Schedule entry conversion works correctly")


def main():
    """Run all tests."""
    print("=" * 70)
    print("MODELPRIVATEATTR FIX VERIFICATION TEST")
    print("=" * 70)
    print()
    
    tests = [
        test_slot_conversion,
        test_lesson_json_conversion,
        test_hyperlinks_iteration,
        test_slot_filtering,
        test_safe_access_patterns,
        test_schedule_entry_conversion,
    ]
    
    passed = 0
    failed = 0
    
    for test in tests:
        try:
            test()
            passed += 1
        except AssertionError as e:
            print(f"   [FAIL] Test failed: {e}")
            failed += 1
        except Exception as e:
            print(f"   [FAIL] Test error: {e}")
            failed += 1
        print()
    
    print("=" * 70)
    print(f"RESULTS: {passed} passed, {failed} failed")
    print("=" * 70)
    
    if failed == 0:
        print("[SUCCESS] All tests passed! ModelPrivateAttr fixes are working correctly.")
        return 0
    else:
        print("[ERROR] Some tests failed. Please review the fixes.")
        return 1


if __name__ == "__main__":
    sys.exit(main())


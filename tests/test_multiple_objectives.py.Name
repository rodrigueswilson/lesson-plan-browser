def test_current_generator():
    """Test how the current generator handles different data structures."""
    print("=" * 80)
    print("TESTING CURRENT GENERATOR WITH DIFFERENT DATA STRUCTURES")
    print("=" * 80)
    print()
    
    generator = ObjectivesPDFGenerator()
    
    # Test 1: Single objective per day (current format)
    print("TEST 1: Single objective per day")
    print("-" * 40)
    
    single_data = create_multi_slot_lesson_data()
    single_objectives = generator.extract_objectives(single_data)
    
    print(f"Extracted {len(single_objectives)} objectives from single-objective format")
    for obj in single_objectives:
        print(f"  {obj['day']}: {obj['subject']} - {obj['unit_lesson'][:50]}...")
    print()
    
    # Test 2: Multiple objectives per day (array format)
    print("TEST 2: Multiple objectives per day (array format)")
    print("-" * 40)
    
    multi_data = create_multi_objective_data()
    multi_objectives = generator.extract_objectives(multi_data)
    
    print(f"Extracted {len(multi_objectives)} objectives from multi-objective format")
    for obj in multi_objectives:
        print(f"  {obj['day']}: {obj['subject']} - {obj['unit_lesson'][:50]}...")
    print()
    
    # Generate HTML with multiple objectives
    print("GENERATING HTML WITH MULTIPLE OBJECTIVES")
    print("-" * 40)
    
    output_dir = Path(tempfile.gettempdir()) / "objectives_demo"
    output_dir.mkdir(exist_ok=True)
    
    # Use single format for now (the generator doesn't support arrays yet)
    html_path = output_dir / "objectives_multiple_slots.html"
    html_path = generator.generate_html(
        single_data,
        str(html_path),
        user_name="Ms. Wilson"
    )
    
    print(f"✓ HTML generated: {html_path}")
    
    # Show the issue
    print("\nCURRENT ISSUE:")
    print("-" * 40)
    print("The ObjectivesPDFGenerator currently only supports one objective per day.")
    print("To show multiple objectives per day, we need to:")
    print("1. Modify extract_objectives() to handle array format")
    print("2. Or create separate HTML pages for each objective")
    print("3. Or combine multiple objectives on the same page")
    
    print("\nThe current implementation assumes one lesson per day.")
    print("For multiple slots per day, the ObjectivesPrinter (DOCX) is better suited.")


if __name__ == "__main__":
    test_current_generator()

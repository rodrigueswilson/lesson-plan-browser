#!/usr/bin/env python3
"""
Test script to demonstrate same-folder objectives generation.
"""

import json
import sys
from pathlib import Path
from datetime import datetime

# Add backend to path
sys.path.append(str(Path(__file__).parent / "backend"))

from backend.services.objectives_pdf_generator import ObjectivesPDFGenerator


def test_same_folder_approach():
    """Test saving objectives in the same folder as DOCX."""
    print("=" * 60)
    print("TESTING SAME-FOLDER OBJECTIVES GENERATION")
    print("=" * 60)
    print()
    
    # Create sample data
    lesson_json = {
        "metadata": {
            "week_of": "11-17-11-21",
            "grade": "3",
            "subject": "ELA", 
            "homeroom": "Room 15",
            "teacher_name": "Ms. Wilson"
        },
        "days": {
            "monday": {
                "unit_lesson": "Unit 3 Lesson 9: MEASURE TO FIND THE AREA",
                "objective": {
                    "content_objective": "Students will measure area using square units.",
                    "student_goal": "I will find the area of shapes using square units.",
                    "wida_objective": "Students will use language to describe areas using mathematical vocabulary (ELD-MA.3-5.Describe.Speaking) by using visual supports and bilingual glossaries."
                }
            }
        }
    }
    
    # Simulate the same folder approach
    test_dir = Path("test_output") / f"same_folder_test_{datetime.now().strftime('%Y%m%d_%H%M%S')}"
    test_dir.mkdir(parents=True, exist_ok=True)
    
    # Simulate existing DOCX file
    docx_filename = "Wilson_Weekly_W47_11-17-11-21_20251116_213107.docx"
    docx_path = test_dir / docx_filename
    
    # Create a dummy DOCX file to simulate existing file
    docx_path.touch()
    
    print(f"Simulating existing DOCX: {docx_path}")
    print()
    
    # Use the SAME folder as DOCX (key change)
    output_dir = docx_path.parent  # SAME folder - not a subdirectory!
    base_name = docx_path.stem
    
    print(f"Output directory: {output_dir}")
    print(f"Base name: {base_name}")
    print()
    
    # Generate objectives in SAME folder
    generator = ObjectivesPDFGenerator()
    
    # HTML file
    html_filename = f"{base_name}_Objectives.html"
    html_path = output_dir / html_filename
    
    generated_html = generator.generate_html(
        lesson_json,
        str(html_path),
        user_name="Ms. Wilson"
    )
    
    print("✅ Files generated in SAME folder:")
    print(f"📄 {docx_path.name}")
    print(f"📄 {Path(generated_html).name}")
    
    # Show the file structure
    print()
    print("File structure:")
    print(f"📁 {test_dir.name}/")
    for file_path in sorted(test_dir.iterdir()):
        size = file_path.stat().st_size
        print(f"   📄 {file_path.name} ({size:,} bytes)")
    
    print()
    print("✅ SUCCESS: All files in the same folder!")
    print("✅ Users can easily find and manage all related files")
    print("✅ No subdirectory navigation needed")
    print("✅ Consistent with existing file organization")
    
    return True


if __name__ == "__main__":
    test_same_folder_approach()

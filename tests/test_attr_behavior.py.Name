from typing import Any

class MockModelPrivateAttr:
    def __repr__(self):
        return "<ModelPrivateAttr>"
    
    def __iter__(self):
        raise TypeError("argument of type 'ModelPrivateAttr' is not iterable")

def test_behavior():
    attr = MockModelPrivateAttr()
    
    print(f"Testing string format: '{attr}'")
    
    try:
        if attr:
            print("Tested boolean evaluation: True")
    except TypeError as e:
        print(f"Boolean evaluation failed: {e}")

    try:
        if "test" in attr:
            print("Tested membership: True")
    except TypeError as e:
        print(f"Membership failed: {e}")

if __name__ == "__main__":
    test_behavior()


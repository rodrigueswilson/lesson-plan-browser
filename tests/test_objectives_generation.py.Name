"""
Test script to generate objectives PDF and HTML from an existing lesson plan JSON file.
This script tests just the objectives generation without going through the entire pipeline.
"""

import json
import sys
from pathlib import Path

# Add parent directory to path to import backend modules
sys.path.insert(0, str(Path(__file__).parent))

from backend.services.objectives_pdf_generator import (
    generate_objectives_pdf,
    generate_objectives_html,
)
from backend.file_manager import get_file_manager


def html_escape(text):
    """Escape HTML special characters."""
    if text is None:
        return ""
    if not isinstance(text, str):
        text = str(text)
    return (text
            .replace("&", "&amp;")
            .replace("<", "&lt;")
            .replace(">", "&gt;")
            .replace('"', "&quot;")
            .replace("'", "&#x27;"))


def get_nested_value(data, *keys, default="N/A"):
    """Safely get nested dictionary values."""
    current = data
    for key in keys:
        if isinstance(current, dict):
            current = current.get(key)
        else:
            return default
        if current is None:
            return default
    if current is None or current == "":
        return default
    return html_escape(str(current))


def format_field(data, field_name, *nested_keys):
    """Format a field, handling both string and nested object formats."""
    value = data.get(field_name)
    if value is None:
        return "N/A"
    
    # If it's a dict, try to get nested values
    if isinstance(value, dict):
        for key in nested_keys:
            if key in value:
                result = value[key]
                if result:
                    return html_escape(str(result))
        # If no nested key found, try to get original_content
        if "original_content" in value:
            return html_escape(str(value["original_content"]))
        # Otherwise return string representation
        return html_escape(str(value))
    
    # If it's a string or other type
    if value:
        return html_escape(str(value))
    return "N/A"


def generate_lesson_plan_html(lesson_json: dict, title: str = "Lesson Plan") -> str:
    """
    Generate an HTML viewer for the lesson plan JSON data.
    
    Args:
        lesson_json: The lesson plan JSON data
        title: Title for the HTML page
    
    Returns:
        HTML content as a string
    """
    metadata = lesson_json.get("metadata", {})
    week_of = html_escape(str(metadata.get("week_of", "Unknown")))
    teacher = html_escape(str(metadata.get("teacher_name", "Unknown")))
    grade = html_escape(str(metadata.get("grade", "Unknown")))
    subject = html_escape(str(metadata.get("subject", "Unknown")))
    homeroom = html_escape(str(metadata.get("homeroom", "Unknown")))
    
    days_html = []
    days_data = lesson_json.get("days", {})
    
    for day_name in ["monday", "tuesday", "wednesday", "thursday", "friday"]:
        if day_name not in days_data:
            continue
        
        day_data = days_data[day_name]
        day_title = day_name.capitalize()
        
        # Handle multi-slot structure
        if "slots" in day_data and isinstance(day_data["slots"], list):
            slots_html = []
            for slot in day_data["slots"]:
                slot_num = slot.get("slot_number", "")
                slot_subject = html_escape(str(slot.get("subject", subject)))
                slot_time = slot.get("time", "")
                if not slot_time and slot.get("start_time"):
                    slot_time = f"{slot.get('start_time', '')}-{slot.get('end_time', '')}"
                slot_time_str = f" ({html_escape(slot_time)})" if slot_time else ""
                
                # Get all the fields with proper handling
                unit_lesson = format_field(slot, "unit_lesson")
                content_obj = format_field(slot, "objective", "content_objective")
                student_goal = format_field(slot, "objective", "student_goal")
                wida_obj = format_field(slot, "objective", "wida_objective")
                anticipatory = format_field(slot, "anticipatory_set", "original_content", "bilingual_bridge")
                instruction = format_field(slot, "tailored_instruction", "original_content")
                misconception = format_field(slot, "misconceptions", "original_content")
                assessment = format_field(slot, "assessment", "primary_assessment")
                homework = format_field(slot, "homework", "original_content")
                
                slot_html = f"""
                <div class="slot">
                    <h4>Slot {slot_num}: {slot_subject}{slot_time_str}</h4>
                    <div class="slot-content">
                        <p><strong>Unit/Lesson:</strong> {unit_lesson}</p>
                        <p><strong>Content Objective:</strong> {content_obj}</p>
                        <p><strong>Student Goal:</strong> {student_goal}</p>
                        <p><strong>WIDA Objective:</strong> {wida_obj}</p>
                        <p><strong>Anticipatory Set:</strong> {anticipatory}</p>
                        <p><strong>Instruction:</strong> {instruction}</p>
                        <p><strong>Misconception:</strong> {misconception}</p>
                        <p><strong>Assessment:</strong> {assessment}</p>
                        <p><strong>Homework:</strong> {homework}</p>
                    </div>
                </div>
                """
                slots_html.append(slot_html)
            
            day_html = f"""
            <div class="day">
                <h3>{day_title}</h3>
                {''.join(slots_html)}
            </div>
            """
        else:
            # Single-slot structure
            unit_lesson = format_field(day_data, "unit_lesson")
            content_obj = format_field(day_data, "objective", "content_objective")
            student_goal = format_field(day_data, "objective", "student_goal")
            wida_obj = format_field(day_data, "objective", "wida_objective")
            anticipatory = format_field(day_data, "anticipatory_set", "original_content")
            instruction = format_field(day_data, "tailored_instruction", "original_content")
            misconception = format_field(day_data, "misconceptions", "original_content")
            assessment = format_field(day_data, "assessment", "primary_assessment")
            homework = format_field(day_data, "homework", "original_content")
            
            day_html = f"""
            <div class="day">
                <h3>{day_title}</h3>
                <div class="slot-content">
                    <p><strong>Unit/Lesson:</strong> {unit_lesson}</p>
                    <p><strong>Content Objective:</strong> {content_obj}</p>
                    <p><strong>Student Goal:</strong> {student_goal}</p>
                    <p><strong>WIDA Objective:</strong> {wida_obj}</p>
                    <p><strong>Anticipatory Set:</strong> {anticipatory}</p>
                    <p><strong>Instruction:</strong> {instruction}</p>
                    <p><strong>Misconception:</strong> {misconception}</p>
                    <p><strong>Assessment:</strong> {assessment}</p>
                    <p><strong>Homework:</strong> {homework}</p>
                </div>
            </div>
            """
        
        days_html.append(day_html)
    
    html_template = f"""
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} - Week of {week_of}</title>
    <style>
        * {{
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }}
        body {{
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            color: #333;
            background-color: #f5f5f5;
            padding: 20px;
        }}
        .container {{
            max-width: 1200px;
            margin: 0 auto;
            background: white;
            padding: 30px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }}
        header {{
            border-bottom: 3px solid #4CAF50;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }}
        h1 {{
            color: #4CAF50;
            margin-bottom: 10px;
        }}
        .metadata {{
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-top: 15px;
        }}
        .metadata-item {{
            background: #f9f9f9;
            padding: 10px;
            border-radius: 5px;
        }}
        .metadata-item strong {{
            color: #666;
            display: block;
            margin-bottom: 5px;
        }}
        .day {{
            margin-bottom: 30px;
            border: 1px solid #ddd;
            border-radius: 8px;
            padding: 20px;
            background: #fafafa;
        }}
        .day h3 {{
            color: #4CAF50;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid #4CAF50;
        }}
        .slot {{
            margin-bottom: 20px;
            padding: 15px;
            background: white;
            border-radius: 5px;
            border-left: 4px solid #2196F3;
        }}
        .slot h4 {{
            color: #2196F3;
            margin-bottom: 10px;
        }}
        .slot-content p {{
            margin-bottom: 10px;
            padding: 5px 0;
            word-wrap: break-word;
            overflow-wrap: break-word;
            white-space: pre-wrap;
        }}
        .slot-content strong {{
            color: #555;
            min-width: 150px;
            display: inline-block;
            vertical-align: top;
        }}
        .slot-content p:last-child {{
            margin-bottom: 0;
        }}
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>{title}</h1>
            <div class="metadata">
                <div class="metadata-item">
                    <strong>Week of:</strong>
                    {week_of}
                </div>
                <div class="metadata-item">
                    <strong>Teacher:</strong>
                    {teacher}
                </div>
                <div class="metadata-item">
                    <strong>Grade:</strong>
                    {grade}
                </div>
                <div class="metadata-item">
                    <strong>Subject:</strong>
                    {subject}
                </div>
                <div class="metadata-item">
                    <strong>Homeroom:</strong>
                    {homeroom}
                </div>
            </div>
        </header>
        
        <main>
            {''.join(days_html)}
        </main>
    </div>
</body>
</html>
    """
    
    return html_template


def test_objectives_generation(json_file_path: str, user_name: str = None):
    """
    Test objectives PDF and HTML generation from a JSON file.
    
    Args:
        json_file_path: Path to the lesson plan JSON file
        user_name: Optional user name for file naming
    """
    print(f"Reading JSON file: {json_file_path}")
    
    # Read the JSON file
    json_path = Path(json_file_path)
    if not json_path.exists():
        print(f"ERROR: JSON file not found: {json_file_path}")
        return
    
    with open(json_path, "r", encoding="utf-8") as f:
        lesson_json = json.load(f)
    
    print(f"[OK] JSON file loaded successfully")
    print(f"  Week of: {lesson_json.get('metadata', {}).get('week_of', 'Unknown')}")
    print(f"  Teacher: {lesson_json.get('metadata', {}).get('teacher_name', 'Unknown')}")
    print(f"  Days: {list(lesson_json.get('days', {}).keys())}")
    
    # Determine output folder (same as JSON file)
    output_folder = json_path.parent
    base_name = json_path.stem
    
    # Sanitize lesson_json to remove ModelPrivateAttr objects
    print("\n" + "="*60)
    print("Sanitizing lesson JSON...")
    print("="*60)
    
    def sanitize_value(value):
        """Recursively sanitize a value to remove ModelPrivateAttr objects."""
        # Check for ModelPrivateAttr
        if hasattr(value, "__class__") and "ModelPrivateAttr" in str(type(value)):
            return None
        # Handle lists
        if isinstance(value, list):
            return [sanitize_value(item) for item in value]
        # Handle dicts
        if isinstance(value, dict):
            return {k: sanitize_value(v) for k, v in value.items()}
        return value
    
    lesson_json = sanitize_value(lesson_json)
    print("[OK] Lesson JSON sanitized successfully")
    
    # Generate objectives HTML (PDF is optional)
    print("\n" + "="*60)
    print("Generating objectives HTML...")
    print("="*60)
    
    objectives_html_path = None
    objectives_pdf_path = None
    
    # Try to generate HTML directly (more reliable than PDF)
    try:
        objectives_html_path = output_folder / f"{base_name}_objectives.html"
        print(f"\nGenerating HTML: {objectives_html_path}")
        
        generate_objectives_html(
            lesson_json,
            str(objectives_html_path),
            user_name=user_name,
        )
        
        print(f"[OK] HTML generated successfully: {objectives_html_path}")
        if objectives_html_path.exists():
            print(f"  HTML file size: {objectives_html_path.stat().st_size:,} bytes")
    except Exception as html_err:
        print(f"[WARNING] HTML generation failed: {html_err}")
        objectives_html_path = None
    
    # Try PDF generation (optional - may fail if playwright not installed)
    try:
        objectives_pdf_path = output_folder / f"{base_name}_objectives.pdf"
        print(f"\nGenerating PDF (optional): {objectives_pdf_path}")
        
        generate_objectives_pdf(
            lesson_json,
            str(objectives_pdf_path),
            user_name=user_name,
            keep_html=True,  # Keep HTML file
        )
        
        print(f"[OK] PDF generated successfully: {objectives_pdf_path}")
        if objectives_pdf_path.exists():
            print(f"  PDF file size: {objectives_pdf_path.stat().st_size:,} bytes")
    except Exception as pdf_err:
        print(f"[WARNING] PDF generation failed (this is OK if playwright is not installed): {pdf_err}")
        objectives_pdf_path = None
    
    # Generate HTML viewer for the lesson plan (from JSON) - always run this
    print("\n" + "="*60)
    print("Generating lesson plan HTML viewer...")
    print("="*60)
    
    lesson_plan_html_path = output_folder / f"{base_name}_viewer.html"
    try:
        html_content = generate_lesson_plan_html(lesson_json, json_path.stem)
        with open(lesson_plan_html_path, "w", encoding="utf-8") as f:
            f.write(html_content)
        print(f"[OK] Lesson plan HTML viewer created: {lesson_plan_html_path}")
    except Exception as e:
        print(f"[WARNING] Could not create lesson plan HTML viewer: {e}")
        import traceback
        traceback.print_exc()
        lesson_plan_html_path = None
        
        print("\n" + "="*60)
        print("SUCCESS: Generation completed!")
        print("="*60)
        print(f"\nFiles created:")
        if objectives_pdf_path and objectives_pdf_path.exists():
            print(f"  Objectives PDF: {objectives_pdf_path}")
        if objectives_html_path and objectives_html_path.exists():
            print(f"  Objectives HTML: {objectives_html_path}")
        if lesson_plan_html_path and lesson_plan_html_path.exists():
            print(f"  Lesson Plan Viewer: {lesson_plan_html_path}")
        print(f"\nDOCX file: {json_path.with_suffix('.docx')}")
        
        # Try to open the files
        import webbrowser
        import os
        
        print("\n" + "="*60)
        print("Opening files...")
        print("="*60)
        
        # Open lesson plan HTML viewer in browser (PRIORITY - this is what the user wants to see)
        if lesson_plan_html_path and lesson_plan_html_path.exists():
            html_uri = lesson_plan_html_path.as_uri()
            print(f"Opening lesson plan viewer in browser: {html_uri}")
            webbrowser.open(html_uri)
            print("[OK] Lesson plan viewer opened in browser!")
        
        # Open objectives HTML in browser (secondary)
        if objectives_html_path and objectives_html_path.exists():
            html_uri = objectives_html_path.as_uri()
            print(f"Opening objectives HTML in browser: {html_uri}")
            webbrowser.open_new_tab(html_uri)
        
        # Open DOCX if it exists (will open in Word/default viewer)
        docx_path = json_path.with_suffix('.docx')
        if docx_path.exists():
            print(f"Opening DOCX in default viewer: {docx_path}")
            os.startfile(str(docx_path))
        
        # Open PDF if it exists (will open in PDF viewer)
        if objectives_pdf_path and objectives_pdf_path.exists():
            print(f"Opening PDF in default viewer: {objectives_pdf_path}")
            os.startfile(str(objectives_pdf_path))
        
        print("\n[OK] Files opened successfully!")
        
    except Exception as e:
        print(f"\n" + "="*60)
        print("ERROR: Objectives generation failed!")
        print("="*60)
        print(f"Error: {str(e)}")
        print(f"Error type: {type(e).__name__}")
        import traceback
        print("\nTraceback:")
        traceback.print_exc()
        return False
    
    return True



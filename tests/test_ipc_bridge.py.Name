#!/usr/bin/env python3
"""
Test script for IPC bridge communication.
This simulates the Python sidecar to test Rust ↔ Python IPC.
"""

import json
import sys
import subprocess
import time
from pathlib import Path

def test_ipc_echo():
    """Test basic echo communication."""
    print("Testing IPC Bridge - Echo Test")
    print("=" * 50)
    
    # Test message
    test_message = {
        "type": "command",
        "request_id": "test-123",
        "command": "health_check",
        "user_id": None
    }
    
    print(f"Sending: {json.dumps(test_message)}")
    
    # For this test, we'll create a simple Python script that echoes back
    # In real usage, this would be backend/sidecar_main.py
    echo_script = """
import json
import sys

while True:
    line = sys.stdin.readline()
    if not line:
        break
    line = line.strip()
    if not line:
        continue
    
    try:
        msg = json.loads(line)
        if msg.get("type") == "command" and msg.get("command") == "health_check":
            response = {
                "type": "response",
                "request_id": msg.get("request_id"),
                "status": "success",
                "data": {"status": "healthy", "timestamp": "2025-01-01T00:00:00"}
            }
            print(json.dumps(response), flush=True)
    except Exception as e:
        error_response = {
            "type": "response",
            "request_id": msg.get("request_id", "unknown"),
            "status": "error",
            "error": str(e)
        }
        print(json.dumps(error_response), flush=True)
"""
    
    # Write temporary script
    script_path = Path("test_echo_sidecar.py")
    script_path.write_text(echo_script)
    
    try:
        # Spawn Python process
        proc = subprocess.Popen(
            [sys.executable, str(script_path)],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1
        )
        
        # Send test message
        proc.stdin.write(json.dumps(test_message) + "\n")
        proc.stdin.flush()
        
        # Read response
        response_line = proc.stdout.readline()
        if response_line:
            response = json.loads(response_line.strip())
            print(f"Received: {json.dumps(response, indent=2)}")
            
            if response.get("status") == "success":
                print("\n[PASS] IPC Echo Test PASSED")
                return True
            else:
                print(f"\n[FAIL] IPC Echo Test FAILED: {response.get('error')}")
                return False
        else:
            print("\n[FAIL] IPC Echo Test FAILED: No response")
            return False
            
    except Exception as e:
        print(f"\n[FAIL] IPC Echo Test FAILED: {e}")
        return False
    finally:
        if proc:
            proc.terminate()
            proc.wait()
        if script_path.exists():
            script_path.unlink()


def test_database_operations():
    """Test database operations through IPC adapter."""
    print("\n\nTesting IPC Database Adapter")
    print("=" * 50)
    
    # This test requires the actual Rust bridge to be running
    # For now, we'll just verify the IPC adapter can be imported
    try:
        sys.path.insert(0, str(Path(__file__).parent))
        from backend.ipc_database import IPCDatabaseAdapter
        
        adapter = IPCDatabaseAdapter()
        print("[PASS] IPC Database Adapter imported successfully")
        print("  Note: Full database tests require Rust bridge to be running")
        return True
    except Exception as e:
        print(f"[FAIL] IPC Database Adapter import FAILED: {e}")
        return False


def test_sidecar_main():
    """Test sidecar main module."""
    print("\n\nTesting Sidecar Main Module")
    print("=" * 50)
    
    try:
        sys.path.insert(0, str(Path(__file__).parent))
        from backend.sidecar_main import SyncSidecar
        
        sidecar = SyncSidecar()
        print("[PASS] Sidecar Main module imported successfully")
        print("  Note: Full sync tests require Supabase configuration")
        return True
    except Exception as e:
        print(f"[FAIL] Sidecar Main module import FAILED: {e}")
        import traceback
        traceback.print_exc()
        return False


if __name__ == "__main__":
    print("IPC Bridge Desktop Test Suite")
    print("=" * 50)
    
    results = []
    results.append(("Echo Test", test_ipc_echo()))
    results.append(("Database Adapter", test_database_operations()))
    results.append(("Sidecar Main", test_sidecar_main()))
    
    print("\n\nTest Results Summary")
    print("=" * 50)
    for name, passed in results:
        status = "[PASS]" if passed else "[FAIL]"
        print(f"{name}: {status}")
    
    all_passed = all(result[1] for result in results)
    if all_passed:
        print("\n[PASS] All tests passed!")
        sys.exit(0)
    else:
        print("\n[FAIL] Some tests failed")
        sys.exit(1)


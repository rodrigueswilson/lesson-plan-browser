"""
Test if JSON serialization is working correctly for vocabulary_cognates.
"""
import sys
import json
from pathlib import Path

sys.path.append(str(Path(__file__).parent))

from backend.schema import LessonStep
from sqlmodel import SQLModel, Field, create_engine, Session
from sqlalchemy import Column, JSON
from typing import List, Dict, Any, Optional
from datetime import datetime
import uuid

# Test data
vocabulary_cognates = [
    {"english": "state", "portuguese": "estado", "is_cognate": False, "relevance_note": "Test"},
    {"english": "coast", "portuguese": "costa", "is_cognate": True, "relevance_note": "Test"}
]

sentence_frames = [
    {"proficiency_level": "levels_1_2", "english": "This is a fact: ___", "portuguese": "Este é um fato: ___"}
]

# Create a test step
step_data = {
    "id": str(uuid.uuid4()),
    "lesson_plan_id": "test_plan",
    "day_of_week": "monday",
    "slot_number": 1,
    "step_number": 1,
    "step_name": "Test Step",
    "duration_minutes": 5,
    "start_time_offset": 0,
    "content_type": "instruction",
    "display_content": "Test",
    "hidden_content": [],
    "sentence_frames": sentence_frames,
    "materials_needed": [],
    "vocabulary_cognates": vocabulary_cognates,
}

print("Creating LessonStep with vocabulary_cognates...")
print(f"  vocabulary_cognates type: {type(step_data['vocabulary_cognates'])}")
print(f"  vocabulary_cognates value: {step_data['vocabulary_cognates']}")
print(f"  sentence_frames type: {type(step_data['sentence_frames'])}")
print(f"  sentence_frames value: {step_data['sentence_frames']}")

try:
    step = LessonStep(**step_data)
    print(f"\n[OK] LessonStep created successfully")
    print(f"  step.vocabulary_cognates type: {type(step.vocabulary_cognates)}")
    print(f"  step.vocabulary_cognates value: {step.vocabulary_cognates}")
    print(f"  step.sentence_frames type: {type(step.sentence_frames)}")
    print(f"  step.sentence_frames value: {step.sentence_frames}")
    
    # Check if SQLModel serializes it automatically
    print(f"\nChecking SQLModel serialization...")
    
    # Try to access the internal dict representation
    if hasattr(step, '__dict__'):
        print(f"  __dict__ keys: {list(step.__dict__.keys())}")
        if 'vocabulary_cognates' in step.__dict__:
            print(f"  __dict__['vocabulary_cognates']: {step.__dict__['vocabulary_cognates']}")
        if 'sentence_frames' in step.__dict__:
            print(f"  __dict__['sentence_frames']: {step.__dict__['sentence_frames']}")
    
    # Try model_dump() if available
    if hasattr(step, 'model_dump'):
        dumped = step.model_dump()
        print(f"\n  model_dump() vocabulary_cognates: {dumped.get('vocabulary_cognates')}")
        print(f"  model_dump() sentence_frames: {dumped.get('sentence_frames')}")
    
    print(f"\n[SUCCESS] Test completed")
    
except Exception as e:
    print(f"\n[FAIL] Error: {e}")
    import traceback
    traceback.print_exc()

